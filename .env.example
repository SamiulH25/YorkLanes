# YorkLanes env templates — copy these into the app folders:
#
#   cp apps/api/.env.example apps/api/.env
#   cp apps/web/.env.example apps/web/.env.local
#
# Fill in values from the database maintainer (SUPABASE_DB_URL, OAuth creds).
# Never commit apps/api/.env or apps/web/.env.local.
#
# Google OAuth setup: docs/tasks/auth.md
