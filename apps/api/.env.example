# Copy to apps/api/.env — get real values from the database maintainer.
# Setup guide: docs/tasks/auth.md

# --- Database (required) ---
SUPABASE_DB_URL=

# --- Server (required) ---
API_PORT=3001
WEB_ORIGIN=http://localhost:4321

# --- Google OAuth (optional until sign-in is needed) ---
# Maintainer: Google Cloud Console → Google Auth Platform → Clients → Web application
# Redirect URI must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4321/api/auth/google/callback
# Random string (32+ chars). PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})
SESSION_SECRET=

# --- Production only (npm run start:prod) ---
# NODE_ENV=production

# --- Checklist import (optional) ---
# PYTHON_PATH=services/checklist-parser/.venv/Scripts/python.exe
