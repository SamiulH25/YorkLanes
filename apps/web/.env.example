# Copy to apps/web/.env.local — get values from the database maintainer.
# Setup guide: docs/tasks/auth.md

# Dev (npm run start:dev): use the web origin so /api is proxied and auth cookies work.
PUBLIC_API_URL=http://localhost:4321

# Prod local (npm run start:prod): no dev proxy — point at the API directly.
# PUBLIC_API_URL=http://localhost:3001
