---
interface Props {
  featureName: string;
  owner: string;
  taskDoc: string;
  apiHint: string;
  apiMessage?: string;
  steps: string[];
}

const { featureName, owner, taskDoc, apiHint, apiMessage, steps } = Astro.props;
---

<div class="mx-auto max-w-2xl">
  <div class="surface-elevated p-8 md:p-10">
    <div class="flex items-start gap-4">
      <div class="icon-badge bg-york-red/10 text-york-red">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
        </svg>
      </div>
      <div>
        <p class="label">{featureName}</p>
        <p class="mt-1 text-sm font-medium text-york-muted">Owner: {owner}</p>
      </div>
    </div>

    {
      apiMessage && (
        <p class="mt-5 rounded-xl surface-muted px-4 py-3 text-sm text-stone-600 dark:text-stone-400">
          <span class="font-semibold text-york-black dark:text-white">API:</span> {apiMessage}
        </p>
      )
    }

    <p class="mt-5 text-sm leading-relaxed text-stone-600 dark:text-stone-400">{apiHint}</p>

    <p class="mt-5 text-sm">
      <span class="font-medium text-york-muted">Task guide:</span>
      <code class="ml-1.5 rounded-lg bg-york-stone/40 px-2 py-1 text-xs dark:bg-white/10">{taskDoc}</code>
    </p>

    <p class="mt-8 text-sm font-semibold text-york-black dark:text-white">Where to start</p>
    <ol class="mt-3 space-y-2">
      {
        steps.map((step, i) => (
          <li class="flex gap-3 text-sm text-stone-600 dark:text-stone-400">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-york-red/10 text-xs font-bold text-york-red">
              {i + 1}
            </span>
            {step}
          </li>
        ))
      }
    </ol>
  </div>
</div>
