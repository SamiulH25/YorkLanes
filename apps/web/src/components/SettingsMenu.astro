---
import { themes } from "../lib/themes";

interface Props {
  showAccount?: boolean;
  signedIn?: boolean;
  displayName?: string;
  signOutUrl?: string;
}

const {
  showAccount = false,
  signedIn = false,
  displayName = "Account",
  signOutUrl = "/login",
} = Astro.props;

const swatches: Record<string, string> = Object.fromEntries(themes.map((t) => [t.id, t.swatch]));
---

<div class="settings-menu relative" data-settings-menu>
  <button
    type="button"
    data-settings-toggle
    class="btn-ghost flex h-9 w-9 items-center justify-center p-0 sm:h-10 sm:w-10"
    aria-expanded="false"
    aria-haspopup="dialog"
    aria-controls="settings-panel"
    title="Settings"
  >
    <span class="sr-only">Open settings</span>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
      />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
  </button>

  <div
    id="settings-panel"
    data-settings-panel
    class="settings-panel hidden"
    role="dialog"
    aria-label="Settings"
    aria-modal="true"
  >
    <div class="flex items-center justify-between gap-3 border-b border-border px-4 py-3">
      <p class="font-display text-sm font-semibold text-foreground">Settings</p>
      <button
        type="button"
        data-settings-close
        class="flex h-8 w-8 items-center justify-center rounded-[var(--theme-radius-button)] text-muted transition-colors hover:bg-surface-muted hover:text-foreground"
        aria-label="Close settings"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="max-h-[min(70vh,28rem)] overflow-y-auto px-4 py-4">
      <section>
        <p class="label">Theme</p>
        <ul class="mt-2 space-y-1.5" role="list">
          {
            themes.map((theme) => (
              <li>
                <button
                  type="button"
                  data-theme-id={theme.id}
                  class="settings-theme-option flex w-full items-center gap-3 rounded-[var(--theme-radius-button)] border border-transparent px-3 py-2.5 text-left transition-colors hover:bg-surface-muted"
                >
                  <span
                    class="theme-swatch h-9 w-9 shrink-0 rounded-[var(--theme-radius-button)] border-2 border-transparent"
                    style={`background: ${swatches[theme.id]}`}
                    aria-hidden="true"
                  />
                  <span class="min-w-0 flex-1">
                    <span class="block text-sm font-semibold text-foreground">{theme.label}</span>
                    <span class="block text-xs text-muted">{theme.description}</span>
                  </span>
                </button>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="mt-5">
        <p class="label">Appearance</p>
        <div
          class="mode-toggle mt-2 grid grid-cols-2 gap-1 rounded-[var(--theme-radius-button)] border border-border bg-surface-muted p-1"
          role="group"
          aria-label="Color mode"
        >
          <button
            type="button"
            data-mode-pick="light"
            class="mode-pick rounded-[var(--theme-radius-button)] px-3 py-2 text-sm font-medium text-muted transition-colors"
          >
            Light
          </button>
          <button
            type="button"
            data-mode-pick="dark"
            class="mode-pick rounded-[var(--theme-radius-button)] px-3 py-2 text-sm font-medium text-muted transition-colors"
          >
            Dark
          </button>
        </div>
      </section>

      {
        showAccount && (
          <section class="mt-5 border-t border-border pt-5">
            <p class="label">Account</p>
            <p class="mt-2 truncate text-sm font-medium text-foreground">{displayName}</p>
            <div class="mt-3 flex flex-col gap-2">
              {
                signedIn ? (
                  <a href={signOutUrl} data-astro-reload class="btn-ghost w-full justify-center text-sm">
                    Sign out
                  </a>
                ) : (
                  <a href="/login" class="btn-york w-full justify-center text-sm">
                    Sign in
                  </a>
                )
              }
              <a href="/onboarding" class="btn-ghost w-full justify-center text-sm">
                Setup wizard
              </a>
            </div>
          </section>
        )
      }
    </div>
  </div>
</div>

<script>
  import { initSettingsMenu } from "../scripts/settings-menu.ts";
  initSettingsMenu();
</script>

<style>
  :global(html[data-theme="york"] .settings-theme-option[data-theme-id="york"]),
  :global(html[data-theme="midnight"] .settings-theme-option[data-theme-id="midnight"]),
  :global(html[data-theme="retro"] .settings-theme-option[data-theme-id="retro"]),
  :global(html[data-theme="paper"] .settings-theme-option[data-theme-id="paper"]),
  :global(.settings-theme-option.is-active) {
    border-color: color-mix(in srgb, var(--theme-primary) 35%, transparent);
    background: color-mix(in srgb, var(--theme-primary) 8%, transparent);
  }

  :global(html[data-theme="york"] .settings-theme-option[data-theme-id="york"] .theme-swatch),
  :global(html[data-theme="midnight"] .settings-theme-option[data-theme-id="midnight"] .theme-swatch),
  :global(html[data-theme="retro"] .settings-theme-option[data-theme-id="retro"] .theme-swatch),
  :global(html[data-theme="paper"] .settings-theme-option[data-theme-id="paper"] .theme-swatch),
  :global(.settings-theme-option.is-active .theme-swatch) {
    border-color: var(--theme-primary);
    box-shadow: var(--theme-shadow-button);
  }

  :global(html:not(.dark) .mode-pick[data-mode-pick="light"]),
  :global(html:not(.dark) .mode-pick.is-active[data-mode-pick="light"]) {
    background: var(--theme-primary);
    color: var(--theme-on-primary);
  }

  :global(html.dark .mode-pick[data-mode-pick="dark"]),
  :global(html.dark .mode-pick.is-active[data-mode-pick="dark"]) {
    background: var(--theme-primary);
    color: var(--theme-on-primary);
  }
</style>
