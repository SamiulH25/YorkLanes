---
/** York University red U mark, cropped from the official wordmark */
interface Props {
  class?: string;
}

const { class: className = "h-9 w-[2.25rem]" } = Astro.props;
---

<div class:list={["relative shrink-0 overflow-hidden", className]}>
  <img
    src="/york-u-logo.png"
    alt="York University"
    class="absolute right-0 top-0 h-full w-auto max-w-none"
    loading="eager"
    decoding="async"
  />
</div>
