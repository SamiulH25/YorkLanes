---
/** York University red U mark, cropped from the official wordmark. */
interface Props {
  class?: string;
}

const { class: className = "h-9 w-9" } = Astro.props;
---

<img
  src="/york-u-mark.png"
  alt="York University"
  class:list={[className, "shrink-0 object-contain"]}
  loading="eager"
  decoding="async"
/>
