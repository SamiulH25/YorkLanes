---
import type { DashboardSummary } from "../../types/dashboard";

interface Props {
  finance: DashboardSummary["finance"];
}

const { finance } = Astro.props;

const money = new Intl.NumberFormat("en-CA", {
  style: "currency",
  currency: finance.currency || "CAD",
});

const formattedBalance = money.format(finance.balance);
const formattedIncome = money.format(finance.income);
const formattedExpenses = money.format(finance.expenses);
const formattedSpent = money.format(finance.monthSpent);
const formattedBudget = money.format(finance.monthBudget);
const formattedRemaining = money.format(finance.monthRemaining);

const monthLabel = (() => {
  const date = new Date(`${finance.month}-01T00:00:00`);
  if (Number.isNaN(date.getTime())) return finance.month;
  return date.toLocaleDateString("en-CA", { month: "short", year: "numeric" });
})();

const hasBudget = finance.monthBudget > 0;
const overspent = hasBudget && finance.monthSpent > finance.monthBudget;
const budgetPercent = hasBudget
  ? Math.min(100, Math.round((finance.monthSpent / finance.monthBudget) * 100))
  : 0;
---

<section class="surface p-6">
  <div class="widget-header">
    <div>
      <p class="label">Student budget</p>
      <h2 class="heading-widget mt-1">Finances</h2>
    </div>
    <div class="flex items-center gap-2">
      <a href="/finance" class="btn-ghost px-3 py-2 text-xs sm:text-sm">
        Open finances
      </a>
      <div class="icon-badge bg-york-gold/15 text-york-gold">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
    </div>
  </div>

  <div class="mt-5 flex items-end justify-between gap-4">
    <div>
      <p class="label">Balance</p>
      <p class="mt-1 font-display text-3xl font-semibold text-york-black dark:text-white">{formattedBalance}</p>
    </div>
    {
      finance.linked ? (
        <p class="text-xs font-semibold text-emerald-700 dark:text-emerald-300">Synced</p>
      ) : (
        <p class="text-xs font-semibold text-york-gold">Local draft on Finances</p>
      )
    }
  </div>

  <div class="mt-5 grid gap-3 sm:grid-cols-2">
    <div class="surface-muted rounded-xl px-4 py-3">
      <p class="label">Income</p>
      <p class="mt-1 font-display text-xl font-semibold text-emerald-700 dark:text-emerald-300">{formattedIncome}</p>
    </div>
    <div class="surface-muted rounded-xl px-4 py-3">
      <p class="label">Expenses</p>
      <p class="mt-1 font-display text-xl font-semibold text-york-red">{formattedExpenses}</p>
    </div>
  </div>

  <div class="mt-5">
    <div class="flex items-center justify-between gap-3 text-xs">
      <span class="font-semibold text-york-black dark:text-white">{monthLabel} budget</span>
      <span class="text-york-muted">
        {formattedSpent} spent
        {hasBudget ? ` · ${formattedBudget} budget` : ""}
      </span>
    </div>
    <div class="mt-2 h-2 overflow-hidden rounded-full bg-york-cream dark:bg-york-graphite">
      <div
        class:list={[
          "h-full rounded-full transition-[width] duration-200",
          overspent ? "bg-york-red" : "bg-emerald-600",
        ]}
        style={`width: ${hasBudget ? Math.max(budgetPercent, finance.monthSpent > 0 ? 8 : 0) : 0}%`}
      ></div>
    </div>
    <p class="mt-2 text-xs text-york-muted">
      {
        hasBudget
          ? overspent
            ? `Over budget by ${money.format(Math.abs(finance.monthRemaining))}.`
            : `${formattedRemaining} remaining this month.`
          : finance.linked
            ? "Set a monthly budget on Finances to track spending here."
            : "Guest totals stay on the Finances page until you sign in."
      }
    </p>
  </div>

  {
    finance.message && (
      <p class="mt-4 rounded-lg surface-muted px-3 py-2 text-xs leading-relaxed text-york-muted">{finance.message}</p>
    )
  }

  {
    !finance.linked && (
      <a href="/finance" class="btn-york mt-4 inline-flex w-full justify-center sm:w-auto">
        Go to Finances
      </a>
    )
  }
</section>
