---
import type { DashboardSummary } from "../../types/dashboard";

interface Props {
  progress: DashboardSummary["progress"];
}

const { progress } = Astro.props;
const radius = 52;
const circumference = 2 * Math.PI * radius;
const offset = circumference - (progress.percentComplete / 100) * circumference;
---

<section class="surface relative h-full overflow-hidden p-6">
  <div class="widget-glow pointer-events-none absolute -right-8 -top-8 h-32 w-32 rounded-full blur-2xl"></div>

  <div class="widget-header">
    <div>
      <p class="label">Your degree</p>
      <h2 class="heading-widget mt-1">Progress</h2>
    </div>
    <span class="badge bg-brand-subtle text-brand">Fall 2025</span>
  </div>

  <div class="mt-8 flex flex-col items-center gap-8 sm:flex-row">
    <div class="relative h-36 w-36 shrink-0">
      <svg class="h-36 w-36 -rotate-90" viewBox="0 0 120 120" aria-hidden="true">
        <circle cx="60" cy="60" r={radius} fill="none" class="chart-track" stroke-width="9"></circle>
        <circle
          cx="60"
          cy="60"
          r={radius}
          fill="none"
          class="chart-fill"
          stroke-width="9"
          stroke-dasharray={circumference}
          stroke-dashoffset={offset}
          stroke-linecap="round"
        ></circle>
      </svg>
      <span class="absolute inset-0 flex flex-col items-center justify-center">
        <span class="font-display text-3xl font-bold text-foreground">{progress.percentComplete}%</span>
        <span class="text-xs font-medium text-muted">complete</span>
      </span>
    </div>

    <div class="flex-1 text-center sm:text-left">
      <p class="text-secondary text-sm leading-relaxed">{progress.label}</p>
      <div class="mt-5 space-y-2.5">
        <div class="flex items-center gap-2.5 text-xs font-medium text-muted">
          <span class="chart-dot-1 h-2 w-2 rounded-full"></span>
          Major requirements
        </div>
        <div class="flex items-center gap-2.5 text-xs font-medium text-muted">
          <span class="chart-dot-2 h-2 w-2 rounded-full"></span>
          General education
        </div>
        <div class="flex items-center gap-2.5 text-xs font-medium text-muted">
          <span class="chart-dot-3 h-2 w-2 rounded-full"></span>
          Electives
        </div>
      </div>
    </div>
  </div>
</section>
