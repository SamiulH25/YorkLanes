---
import type { QuickLink } from "../../types/dashboard";

interface Props {
  links: QuickLink[];
}

const { links } = Astro.props;

const statusLabel: Record<QuickLink["status"], string> = {
  "not-started": "Coming soon",
  "in-progress": "In progress",
  ready: "Ready",
};

const statusClass: Record<QuickLink["status"], string> = {
  "not-started": "badge-muted",
  "in-progress": "badge-progress",
  ready: "badge-ready",
};
---

<section class="surface p-6">
  <p class="label">Tools</p>
  <h2 class="heading-widget mt-1">Plan your semester</h2>
  <p class="mt-1 text-sm text-muted">Courses, schedule, finances, and the rest.</p>

  <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      links.map((link) => (
        <li>
          {
            link.href ? (
              <a href={link.href} class="link-card group flex h-full flex-col p-4">
                <span class="font-semibold text-foreground transition-colors group-hover:text-brand">
                  {link.label}
                </span>
                <span class:list={["badge mt-3 w-fit", statusClass[link.status]]}>
                  {statusLabel[link.status]}
                </span>
                <span class="mt-auto pt-4 text-[11px] font-medium text-muted">{link.featureOwner}</span>
              </a>
            ) : (
              <div class="link-card-disabled flex h-full flex-col p-4" aria-disabled="true">
                <span class="font-semibold text-foreground">{link.label}</span>
                <span class:list={["badge mt-3 w-fit", statusClass[link.status]]}>
                  {statusLabel[link.status]}
                </span>
                <span class="mt-auto pt-4 text-[11px] text-muted">{link.featureOwner}</span>
              </div>
            )
          }
        </li>
      ))
    }
  </ul>
</section>
