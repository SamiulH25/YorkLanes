---
/**
 * Quick links to feature modules.
 *
 * EXPAND HERE: as each feature page is built, update status in
 * apps/api/src/routes/dashboard.ts and enable the route in DashboardLayout.astro
 */
import type { QuickLink } from "../../types/dashboard";

interface Props {
  links: QuickLink[];
}

const { links } = Astro.props;

const statusStyles: Record<QuickLink["status"], string> = {
  "not-started": "bg-gray-100 text-gray-600",
  "in-progress": "bg-yellow-100 text-yellow-800",
  ready: "bg-green-100 text-green-800",
};
---

<section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
  <h2 class="text-sm font-semibold uppercase tracking-wide text-york-muted">Quick Links</h2>
  <p class="mt-1 text-xs text-york-muted">Jump to feature modules as they are built</p>

  <ul class="mt-4 grid gap-3 sm:grid-cols-2">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="flex items-center justify-between rounded-lg border border-gray-200 px-4 py-3 transition-colors hover:border-york-red hover:bg-red-50"
          >
            <span class="text-sm font-medium text-gray-900">{link.label}</span>
            <span class:list={["rounded-full px-2 py-0.5 text-xs font-medium", statusStyles[link.status]]}>
              {link.status}
            </span>
          </a>
          <p class="mt-1 px-1 text-xs text-york-muted">Owner: {link.featureOwner}</p>
        </li>
      ))
    }
  </ul>
</section>
