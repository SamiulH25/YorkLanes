---
import "../styles/global.css";
import { DEFAULT_THEME_ID } from "../lib/themes";

interface Props {
  title?: string;
  /** Lock layout to the visible viewport (login and other full-screen pages). */
  fillViewport?: boolean;
}

const { title = "YorkLanes", fillViewport = false } = Astro.props;
---

<!doctype html>
<html lang="en" class:list={[fillViewport ? "h-dvh overflow-hidden" : "min-h-dvh"]} data-theme={DEFAULT_THEME_ID}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="YorkPath student dashboard for York University" />
    <link rel="icon" type="image/png" href="/york-u-mark.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Libre+Baskerville:wght@400;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Share+Tech+Mono&family=Source+Serif+4:opsz,wght@8..60,400;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ defaultThemeId: DEFAULT_THEME_ID }}>
      (function () {
        var validThemes = ["york", "midnight", "retro", "paper"];
        var themeId = localStorage.getItem("yorklanes-theme-id");
        if (!themeId || validThemes.indexOf(themeId) === -1) {
          themeId = defaultThemeId;
        }
        document.documentElement.dataset.theme = themeId;
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (stored !== "light" && prefersDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body class:list={["page-bg w-full", fillViewport ? "h-dvh overflow-hidden" : "min-h-dvh overflow-x-hidden"]}>
    <slot />
    <script>
      import "../scripts/theme.ts";
    </script>
  </body>
</html>
