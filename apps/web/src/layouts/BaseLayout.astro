---
/**
 * Base HTML shell. All authenticated pages should use DashboardLayout instead.
 */
interface Props {
  title?: string;
}

const { title = "YorkLanes" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="YorkPath student dashboard for York University" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  }
</style>
