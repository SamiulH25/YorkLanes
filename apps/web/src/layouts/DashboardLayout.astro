---
/**
 * Dashboard shell: sidebar navigation + main content area.
 *
 * EXPAND HERE:
 * - Add nav links in the sidebar as feature pages are created under src/pages/
 * - Replace the placeholder user block once Google OAuth is wired up
 */
import BaseLayout from "./BaseLayout.astro";
import YorkMark from "../components/YorkMark.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  activeNav?: "dashboard" | "onboarding" | "plan" | "courses";
}

const { title = "Dashboard | YorkLanes", activeNav = "dashboard" } = Astro.props;

const navItems = [
  { id: "dashboard", label: "Home", href: "/dashboard", icon: "home" },
  { id: "plan", label: "Degree Plan", href: "/plan", icon: "map" },
  { id: "courses", label: "Course Explorer", href: "/courses", icon: "eyeglass" },
  // { id: "schedule", label: "Schedule", href: "/schedule", icon: "calendar" },
  // { id: "progress", label: "Progress", href: "/progress", icon: "chart" },
  // { id: "finance", label: "Finances", href: "/finance", icon: "wallet" },
  // { id: "assignments", label: "Assignments", href: "/assignments", icon: "check" },
];

const icons: Record<string, string> = {
  home: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
  map: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7",
  eyeglass: "M 9 3 A 1 1 0 0 0 9 15 A 1 1 0 0 0 9 3 M 9 5 A 1 1 0 0 0 9 13 A 1 1 0 0 0 9 5 M 14 14 Q 15 13 16 14 L 19 17 Q 20 18 19 19 Q 18 20 17 19 L 14 16 Q 13 15 14 14",
};
---

<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="flex w-[260px] shrink-0 flex-col border-r border-york-stone/50 bg-white/95 dark:border-white/10 dark:bg-york-slate">
      <div class="border-b border-york-stone/50 px-5 py-5 dark:border-white/10">
        <div class="flex items-center gap-3">
          <YorkMark />
          <div>
            <p class="font-display text-lg font-semibold leading-tight text-york-black dark:text-white">YorkLanes</p>
            <p class="text-[11px] font-medium uppercase tracking-widest text-york-red">York University</p>
          </div>
        </div>
      </div>

      <nav class="flex-1 px-3 py-5">
        <p class="mb-2 px-3 text-[11px] font-semibold uppercase tracking-widest text-york-muted">Navigate</p>
        <ul class="space-y-1">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "link-nav",
                    activeNav === item.id && "link-nav-active",
                  ]}
                >
                  <svg class="h-[18px] w-[18px] shrink-0 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.icon] ?? icons.home} />
                  </svg>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="border-t border-york-stone/50 px-5 py-4 dark:border-white/10">
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-york-red/10 font-display text-sm font-semibold text-york-red dark:bg-york-red/20">
            G
          </div>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-medium text-york-black dark:text-white">Guest</p>
            <a href="/login" class="text-xs text-york-red hover:underline">Sign in</a>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <main class="flex min-w-0 flex-1 flex-col">
      <header class="sticky top-0 z-10 flex items-center justify-between border-b border-york-stone/50 bg-york-cream/90 px-8 py-4 backdrop-blur-md dark:border-white/10 dark:bg-york-navy/90">
        <slot name="header" />
        <ThemeToggle />
      </header>

      <div class="flex-1 bg-york-hero px-8 py-7">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>
