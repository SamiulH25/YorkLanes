---
/** Dashboard shell: sidebar + main content. */
import BaseLayout from "./BaseLayout.astro";
import YorkMark from "../components/YorkMark.astro";
import SettingsMenu from "../components/SettingsMenu.astro";
import { fetchSessionUser, signOutUrl } from "../lib/auth";

export const prerender = false;

interface Props {
  title?: string;
  activeNav?:
    | "dashboard"
    | "onboarding"
    | "plan"
    | "courses"
    | "schedule"
    | "progress"
    | "finance"
    | "assignments";
}

const { title = "Dashboard | YorkLanes", activeNav = "dashboard" } = Astro.props;

const cookie = Astro.request.headers.get("cookie");
const sessionUser = await fetchSessionUser(cookie);
const displayName = sessionUser?.displayName ?? "Guest";
const userInitial = displayName.charAt(0).toUpperCase();
const logoutUrl = signOutUrl();

const navGroups = [
  {
    items: [{ id: "dashboard", label: "Home", href: "/dashboard", icon: "home", mobile: true }],
  },
  {
    items: [
      { id: "plan", label: "Degree plan", href: "/plan", icon: "map", mobile: true },
      { id: "progress", label: "Progress", href: "/progress", icon: "chart", mobile: true },
    ],
  },
  {
    items: [
      { id: "courses", label: "Courses", href: "/courses", icon: "book", mobile: true },
      { id: "schedule", label: "Schedule", href: "/schedule", icon: "calendar", mobile: false },
      { id: "assignments", label: "Assignments", href: "/assignments", icon: "check", mobile: true },
    ],
  },
  {
    items: [{ id: "finance", label: "Finances", href: "/finance", icon: "wallet", mobile: false }],
  },
] as const;

type NavItem = (typeof navGroups)[number]["items"][number];
const navItems: NavItem[] = navGroups.flatMap((group) => [...group.items]);
const mobileNavItems = navItems.filter((item) => item.mobile);

const icons: Record<string, string> = {
  home: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
  map: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7",
  book: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  calendar: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
  chart: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  wallet: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z",
  check: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
};
---

<BaseLayout title={title}>
  <script is:inline>
    try {
      if (localStorage.getItem("sidebar-collapsed") === "1") {
        document.documentElement.dataset.sidebarCollapsed = "true";
      }
    } catch (e) {}
  </script>
  <div class="app-shell lg:flex-row">
    <aside
      data-sidebar
      data-collapsed="false"
      class="dashboard-sidebar app-sidebar relative hidden h-dvh max-h-dvh shrink-0 flex-col overflow-hidden border-r transition-[width] duration-200 ease-in-out lg:flex lg:w-[272px]"
    >
      <div class="absolute left-0 top-0 h-1 w-full bg-sidebar-accent"></div>

      <div class="sidebar-brand shrink-0 border-b border-shell px-4 pb-4 pt-6">
        <div class="sidebar-brand-row flex items-start justify-between gap-2">
          <a href="/dashboard" class="flex min-w-0 items-center gap-3 transition-opacity hover:opacity-90" title="YorkLanes">
            <div class="sidebar-brand-mark bg-brand-mark shrink-0 rounded-xl p-1.5">
              <YorkMark />
            </div>
            <div class="sidebar-brand-text min-w-0">
              <p class="font-display text-lg font-semibold leading-tight text-foreground">YorkLanes</p>
              <p class="text-brand text-[10px] font-bold uppercase tracking-[0.2em]">York University</p>
            </div>
          </a>

          <button
            type="button"
            data-sidebar-toggle
            aria-expanded="true"
            aria-label="Collapse sidebar"
            title="Collapse sidebar"
            class="sidebar-collapse-btn btn-ghost inline-flex h-8 w-8 shrink-0 items-center justify-center p-0"
          >
            <svg class="sidebar-chevron h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <rect x="3" y="4" width="18" height="16" rx="2"></rect>
              <path d="M9 4v16"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 10l-2 2 2 2"></path>
            </svg>
          </button>
        </div>
      </div>

      <nav class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 py-5">
        <p class="sidebar-section-label mb-3 px-3 label">Menu</p>
        {
          navGroups.map((group, groupIndex) => (
            <ul class:list={["space-y-1", groupIndex > 0 && "mt-4 border-t border-shell pt-4"]}>
              {
                group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      title={item.label}
                      class:list={["link-nav sidebar-nav-link", activeNav === item.id && "link-nav-active"]}
                    >
                      <span
                        class:list={[
                          "sidebar-nav-icon flex h-8 w-8 shrink-0 items-center justify-center rounded-lg transition-colors",
                          activeNav === item.id ? "nav-icon-bg-active" : "nav-icon-bg",
                        ]}
                      >
                        <svg
                          class="h-[17px] w-[17px] shrink-0"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="1.75"
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.icon] ?? icons.home} />
                        </svg>
                      </span>
                      <span class="sidebar-nav-label truncate">{item.label}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          ))
        }
      </nav>

      <div class="shrink-0 border-t border-shell p-4">
        <div class="sidebar-user surface-muted flex items-center gap-3 p-3">
          <div class="sidebar-user-avatar user-avatar flex h-10 w-10 shrink-0 items-center justify-center rounded-full font-display text-sm font-bold" title={displayName}>
            {userInitial}
          </div>
          <div class="sidebar-user-text min-w-0 flex-1">
            <p class="truncate text-sm font-semibold text-foreground">{displayName}</p>
            {
              sessionUser ? (
                <a href={logoutUrl} class="text-brand text-xs font-medium hover:underline">
                  Sign out
                </a>
              ) : (
                <a href="/login" class="text-brand text-xs font-medium hover:underline">
                  Sign in
                </a>
              )
            }
          </div>
        </div>
      </div>
    </aside>

    <main class="flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden pb-[calc(3.75rem+env(safe-area-inset-bottom,0px))] lg:pb-0">
      <header class="app-header z-20 shrink-0 border-b px-4 py-3 sm:py-4 lg:px-8 lg:py-5">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <slot name="header" />
          </div>
          <div class="shrink-0">
            <SettingsMenu
              showAccount
              signedIn={Boolean(sessionUser)}
              displayName={displayName}
              signOutUrl={logoutUrl}
            />
          </div>
        </div>
      </header>

      <div class="app-canvas min-h-0 flex-1 overflow-y-auto overflow-x-clip px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8">
        <div class="animate-slide-up w-full min-w-0">
          <slot />
        </div>
      </div>
    </main>
  </div>

  <nav
    class="app-sidebar fixed bottom-0 left-0 right-0 z-30 border-t pb-[env(safe-area-inset-bottom,0px)] lg:hidden"
    aria-label="Mobile navigation"
  >
    <ul class="flex items-stretch justify-around px-1 py-1">
      {
        mobileNavItems.map((item) => (
          <li class="flex-1">
            <a
              href={item.href}
              class:list={[
                "flex flex-col items-center gap-0.5 rounded-lg px-2 py-2 text-[10px] font-semibold transition-colors",
                activeNav === item.id ? "text-brand" : "text-muted hover:text-foreground",
              ]}
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d={icons[item.icon] ?? icons.home} />
              </svg>
              <span class="truncate">{item.label.split(" ")[0]}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <script>
    import "../scripts/sidebar.ts";
  </script>
</BaseLayout>

<style>
  html[data-sidebar-collapsed="true"] [data-sidebar],
  [data-sidebar][data-collapsed="true"] {
    width: 4.5rem;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-brand,
  [data-sidebar][data-collapsed="true"] .sidebar-brand {
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-brand-row,
  [data-sidebar][data-collapsed="true"] .sidebar-brand-row {
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-brand > a,
  [data-sidebar][data-collapsed="true"] .sidebar-brand > a,
  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-brand-row > a,
  [data-sidebar][data-collapsed="true"] .sidebar-brand-row > a {
    justify-content: center;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-brand-text,
  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-section-label,
  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-nav-label,
  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-user-text,
  [data-sidebar][data-collapsed="true"] .sidebar-brand-text,
  [data-sidebar][data-collapsed="true"] .sidebar-section-label,
  [data-sidebar][data-collapsed="true"] .sidebar-nav-label,
  [data-sidebar][data-collapsed="true"] .sidebar-user-text {
    display: none;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-nav-link,
  [data-sidebar][data-collapsed="true"] .sidebar-nav-link {
    justify-content: center;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-user,
  [data-sidebar][data-collapsed="true"] .sidebar-user {
    justify-content: center;
    padding: 0.5rem;
  }

  html[data-sidebar-collapsed="true"] [data-sidebar] .sidebar-chevron,
  [data-sidebar][data-collapsed="true"] .sidebar-chevron {
    transform: rotate(180deg);
  }

  .sidebar-chevron {
    transition: transform 200ms ease;
  }
</style>
