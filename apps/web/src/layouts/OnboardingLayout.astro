---
import BaseLayout from "./BaseLayout.astro";
import YorkMark from "../components/YorkMark.astro";
import SettingsMenu from "../components/SettingsMenu.astro";

interface Props {
  title?: string;
  step: number;
  totalSteps?: number;
}

const { title = "Get started | YorkLanes", step, totalSteps = 4 } = Astro.props;
const progress = Math.min(100, Math.round((step / totalSteps) * 100));
---

<BaseLayout title={title} fillViewport>
  <div class="onboarding-shell">
    <header
      class="flex shrink-0 items-center justify-between border-b border-york-stone/50 bg-stone-200/70 px-4 py-2.5 backdrop-blur-xl dark:border-white/[0.06] dark:bg-york-slate/95 sm:px-6"
    >
      <a href="/" class="flex min-w-0 items-center gap-2 transition-opacity hover:opacity-90">
        <div class="rounded-xl bg-york-red/10 p-1 dark:bg-york-red/15">
          <YorkMark class="h-7 w-7 sm:h-8 sm:w-8" />
        </div>
        <div class="min-w-0">
          <p class="truncate font-display text-sm font-semibold leading-tight text-york-black dark:text-white sm:text-base">
            YorkLanes
          </p>
          <p class="text-[9px] font-bold uppercase tracking-[0.18em] text-york-red sm:text-[10px]">
            Setup
          </p>
        </div>
      </a>
      <SettingsMenu />
    </header>

    <div class="shrink-0 border-b border-york-stone/40 px-4 py-3 dark:border-white/[0.06] sm:px-6">
      <div class="mx-auto flex max-w-2xl items-center justify-between gap-4">
        <p class="text-xs font-medium text-york-muted">
          Step {step} of {totalSteps}
        </p>
        <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-york-stone/40 dark:bg-york-graphite">
          <div
            class="h-full rounded-full bg-york-red transition-[width] duration-300"
            style={`width: ${progress}%`}
            role="progressbar"
            aria-valuenow={progress}
            aria-valuemin={0}
            aria-valuemax={100}
          />
        </div>
      </div>
    </div>

    <main class="onboarding-main">
      <div class="onboarding-panel animate-slide-up">
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>
