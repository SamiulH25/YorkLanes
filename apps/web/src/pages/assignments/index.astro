---
/** Assignment calendar — Sarah. Task guide: docs/tasks/assignments.md */
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import {
  fetchAssignments,
  createAssignment,
  updateAssignment,
  deleteAssignment,
  type Assignment,
} from "../../lib/assignments";

export const prerender = false;

let loadError: string | null = null;
let assignments: Assignment[] = [];
let successMessage: string | null = null;
let formError: string | null = null;
let editError: string | null = null;
let editSuccess: string | null = null;

const cookie = Astro.request.headers.get("cookie");

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("_action")?.toString() ?? "";
  const id = formData.get("id")?.toString() ?? "";

  // Handle UPDATE
  if (action === "update" && id) {
    try {
      const title = formData.get("title")?.toString().trim() ?? "";
      const courseCode = formData.get("courseCode")?.toString().trim() ?? "";
      const description = formData.get("description")?.toString().trim() ?? "";
      const dueDate = formData.get("dueDate")?.toString().trim() ?? "";

      if (!title || !courseCode || !dueDate) {
        throw new Error("Title, course code, and due date are required.");
      }

      const updated = await updateAssignment(
        id,
        {
          title,
          courseCode,
          description,
          dueDate,
        },
        cookie,
      );
      editSuccess = `Updated "${updated.title}"`;
    } catch (error) {
      editError =
        error instanceof Error ? error.message : "Failed to update assignment.";
    }
  }

  // Handle DELETE
  if (action === "delete" && id) {
    try {
      await deleteAssignment(id, cookie);
      successMessage = "Assignment deleted successfully";
    } catch (error) {
      editError =
        error instanceof Error ? error.message : "Failed to delete assignment.";
    }
  }

  // Handle CREATE
  if (!action || action === "create") {
    try {
      const title = formData.get("title")?.toString().trim() ?? "";
      const courseCode = formData.get("courseCode")?.toString().trim() ?? "";
      const description = formData.get("description")?.toString().trim() ?? "";
      const dueDate = formData.get("dueDate")?.toString().trim() ?? "";

      if (!title || !courseCode || !dueDate) {
        throw new Error("Title, course code, and due date are required.");
      }

      const created = await createAssignment(
        {
          title,
          courseCode,
          description,
          dueDate,
        },
        cookie,
      );
      successMessage = `Added "${created.title}"`;
    } catch (error) {
      formError =
        error instanceof Error ? error.message : "Failed to add assignment.";
    }
  }
}

try {
  const data = await fetchAssignments(cookie);
  assignments = data.assignments ?? [];
} catch (error) {
  loadError = error instanceof Error ? error.message : "API unavailable";
}

const pendingCount = assignments.filter((item) => !item.done).length;
const inputClass =
  "mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white";

function formatDueDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-CA", {
    weekday: "short",
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

function dueTone(iso: string, done: boolean): "muted" | "soon" | "overdue" {
  if (done) return "muted";
  const due = new Date(iso);
  const now = new Date();
  const days = Math.ceil(
    (due.getTime() - now.getTime()) / (1000 * 60 * 60 * 24),
  );
  if (days < 0) return "overdue";
  if (days <= 7) return "soon";
  return "muted";
}
---

<DashboardLayout title="Assignments | YorkLanes" activeNav="assignments">
  <Fragment slot="header">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-medium text-york-muted">Deadlines</p>
        <h1 class="heading-page">Assignments</h1>
        <p class="mt-0.5 text-sm text-york-muted">
          {
            pendingCount === 0
              ? "Nothing pending right now."
              : `${pendingCount} pending · ${assignments.length} total`
          }
        </p>
      </div>
      <button
        type="button"
        id="show-add-assignment-form-btn"
        class="btn-york shrink-0"
      >
        Add assignment
      </button>
    </div>
  </Fragment>

  {
    loadError && (
      <div class="mb-5 rounded-xl border border-york-gold/40 bg-york-gold/10 px-4 py-3 text-sm text-stone-700 dark:text-stone-200">
        Could not load assignments: {loadError}. Run{" "}
        <code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-xs dark:bg-white/10">
          npm run start:dev
        </code>
      </div>
    )
  }

  {
    successMessage && (
      <div class="mb-5 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-800 dark:text-emerald-200">
        {successMessage}
      </div>
    )
  }

  <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <!-- Left Column: Assignment List -->
    <section class="surface p-5 sm:p-6">
      <div class="widget-header">
        <div>
          <p class="label">Upcoming</p>
          <h2 class="heading-widget mt-1">Your deadlines</h2>
        </div>
        <div class="icon-badge bg-york-red/10 text-york-red">
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.75"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            ></path>
          </svg>
        </div>
      </div>

      {
        assignments.length > 0 ? (
          <ul class="mt-5 space-y-2">
            {assignments.map((assignment) => {
              const tone = dueTone(assignment.dueAt, assignment.done);
              return (
                <li
                  class="assignment-item rounded-xl surface-muted px-4 py-3 transition-colors hover:bg-york-red/[0.04] cursor-pointer"
                  data-id={assignment.id}
                  data-title={assignment.title}
                  data-course={assignment.courseCode}
                  data-description={assignment.description || ""}
                  data-due={assignment.dueAt}
                >
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="flex min-w-0 flex-1 gap-3">
                      <div
                        class:list={[
                          "mt-1 h-full w-1 shrink-0 rounded-full",
                          assignment.done
                            ? "bg-stone-400"
                            : tone === "overdue"
                              ? "bg-york-red"
                              : "bg-york-gold",
                        ]}
                        aria-hidden="true"
                      />
                      <div class="min-w-0">
                        <p
                          class:list={[
                            "text-sm font-semibold text-york-black dark:text-white",
                            assignment.done && "text-york-muted line-through",
                          ]}
                        >
                          {assignment.title}
                        </p>
                        {assignment.description && (
                          <p class="mt-0.5 text-xs text-york-muted">
                            {assignment.description}
                          </p>
                        )}
                        <p class="mt-1 text-xs font-medium text-york-muted">
                          {assignment.courseCode}
                        </p>
                      </div>
                    </div>
                    <div class="flex shrink-0 flex-col items-end gap-2">
                      <time
                        class:list={[
                          "text-xs font-semibold",
                          assignment.done && "text-york-muted",
                          !assignment.done &&
                            tone === "overdue" &&
                            "text-york-red",
                          !assignment.done &&
                            tone === "soon" &&
                            "text-york-gold",
                          !assignment.done &&
                            tone === "muted" &&
                            "text-york-muted",
                        ]}
                        datetime={assignment.dueAt}
                      >
                        Due on {formatDueDate(assignment.dueAt)}
                      </time>
                      {assignment.done ? (
                        <span class="badge bg-emerald-500/15 text-emerald-700 dark:text-emerald-300">
                          Done
                        </span>
                      ) : (
                        <span class="badge bg-york-gold/15 text-york-gold">
                          Pending
                        </span>
                      )}
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        ) : (
          <div class="empty-state mt-6">
            <p class="text-sm font-medium text-york-black dark:text-white">
              No assignments yet
            </p>
            <p class="mt-1 text-sm text-stone-600 dark:text-stone-400">
              Add your first deadline using the form on the right.
            </p>
          </div>
        )
      }
    </section>

    <!-- Right Column: Forms -->
    <div class="space-y-5">
      <!-- Add Assignment Form -->
      <section class="surface h-fit p-5 sm:p-6">
        <div class="widget-header">
          <div>
            <p class="label">New entry</p>
            <h2 class="heading-widget mt-1">Add assignment</h2>
          </div>
        </div>

        {
          formError && (
            <p class="mt-4 rounded-lg border border-york-red/30 bg-york-red/5 px-3 py-2 text-sm text-york-red">
              {formError}
            </p>
          )
        }

        <form
          id="add-assignment-form"
          class:list={["mt-5 space-y-4", !formError && "hidden"]}
          method="POST"
        >
          <input type="hidden" name="_action" value="create" />
          <label class="block">
            <span class="label">Title</span>
            <input
              type="text"
              name="title"
              required
              class={inputClass}
              placeholder="Essay draft"
            />
          </label>
          <label class="block">
            <span class="label">Course code</span>
            <input
              type="text"
              name="courseCode"
              required
              class={inputClass}
              placeholder="CWR 2600"
            />
          </label>
          <label class="block">
            <span class="label">Description</span>
            <input
              type="text"
              name="description"
              class={inputClass}
              placeholder="Optional notes"
            />
          </label>
          <label class="block">
            <span class="label">Due date</span>
            <input type="date" name="dueDate" required class={inputClass} />
          </label>
          <div class="flex flex-wrap gap-2 pt-1">
            <button type="submit" class="btn-york flex-1 sm:flex-none"
              >Save assignment</button
            >
            <button
              type="button"
              id="hide-add-assignment-form-btn"
              class="btn-ghost">Cancel</button
            >
          </div>
        </form>

        <p
          id="add-assignment-form-hint"
          class:list={["mt-5 text-sm text-york-muted", formError && "hidden"]}
        >
          Use <span class="font-medium text-york-black dark:text-white"
            >Add assignment</span
          > in the header to open the form.
        </p>
      </section>

      <!-- Edit Assignment Form -->
      <section class="surface h-fit p-5 sm:p-6">
        <div class="widget-header">
          <div>
            <p class="label">Edit existing assignment</p>
            <h2 class="heading-widget mt-1">Edit assignment</h2>
          </div>
          <button
            type="button"
            id="delete-assignment-btn"
            class="btn-ghost text-york-red hover:bg-york-red/10 hidden"
          >
            Delete
          </button>
        </div>

        {
          editSuccess && (
            <div class="mt-4 rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-800 dark:text-emerald-200">
              {editSuccess}
            </div>
          )
        }

        {
          editError && (
            <p class="mt-4 rounded-lg border border-york-red/30 bg-york-red/5 px-3 py-2 text-sm text-york-red">
              {editError}
            </p>
          )
        }

        <form
          id="edit-assignment-form"
          class="mt-5 space-y-4 hidden"
          method="POST"
        >
          <input type="hidden" name="_action" value="update" />
          <input type="hidden" name="id" id="edit-id" />

          <label class="block">
            <span class="label">Title</span>
            <input
              type="text"
              name="title"
              id="edit-title"
              required
              class={inputClass}
              placeholder="Essay draft"
            />
          </label>
          <label class="block">
            <span class="label">Course code</span>
            <input
              type="text"
              name="courseCode"
              id="edit-course"
              required
              class={inputClass}
              placeholder="CWR 2600"
            />
          </label>
          <label class="block">
            <span class="label">Description</span>
            <input
              type="text"
              name="description"
              id="edit-description"
              class={inputClass}
              placeholder="Optional notes"
            />
          </label>
          <label class="block">
            <span class="label">Due date</span>
            <input
              type="date"
              name="dueDate"
              id="edit-due"
              required
              class={inputClass}
            />
          </label>
          <div class="flex flex-wrap gap-2 pt-1">
            <button type="submit" class="btn-york flex-1 sm:flex-none">
              Update assignment
            </button>
            <button
              type="button"
              id="hide-edit-assignment-form-btn"
              class="btn-ghost"
            >
              Cancel
            </button>
          </div>
        </form>

        <p id="edit-assignment-form-hint" class="mt-5 text-sm text-york-muted">
          Click on an assignment under <span
            class="font-medium text-york-black dark:text-white"
            >Upcoming Deadlines</span
          > to open the form.
        </p>
      </section>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div
    id="delete-modal"
    class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50"
  >
    <div
      class="bg-white dark:bg-york-graphite rounded-2xl p-6 max-w-md w-full mx-4"
    >
      <h3 class="text-lg font-semibold text-york-black dark:text-white">
        Delete Assignment
      </h3>
      <p class="mt-2 text-sm text-york-muted">
        Are you sure you want to delete this assignment?
      </p>
      <div
        id="delete-assignment-info"
        class="mt-3 p-3 rounded-lg bg-york-red/5 border border-york-red/20"
      >
        <p class="text-sm font-medium" id="delete-title"></p>
        <p class="text-xs text-york-muted mt-1" id="delete-course"></p>
        <p class="text-xs text-york-muted" id="delete-due"></p>
      </div>
      <div class="flex gap-3 mt-5">
        <form method="POST" class="flex-1">
          <input type="hidden" name="_action" value="delete" />
          <input type="hidden" name="id" id="delete-id" />
          <button
            type="submit"
            class="w-full btn-york bg-york-red hover:bg-york-red/90"
          >
            Yes, delete
          </button>
        </form>
        <button type="button" id="cancel-delete-btn" class="flex-1 btn-ghost">
          Cancel
        </button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  // Add/Edit form toggle functions
  const showBtn = document.getElementById("show-add-assignment-form-btn");
  const hideBtn = document.getElementById("hide-add-assignment-form-btn");
  const form = document.getElementById("add-assignment-form");
  const hint = document.getElementById("add-assignment-form-hint");

  const editForm = document.getElementById("edit-assignment-form");
  const editHint = document.getElementById("edit-assignment-form-hint");
  const editHideBtn = document.getElementById("hide-edit-assignment-form-btn");
  const deleteBtn = document.getElementById("delete-assignment-btn");

  const deleteModal = document.getElementById("delete-modal");
  const cancelDeleteBtn = document.getElementById("cancel-delete-btn");
  const deleteIdInput = document.getElementById("delete-id");
  const deleteTitleEl = document.getElementById("delete-title");
  const deleteCourseEl = document.getElementById("delete-course");
  const deleteDueEl = document.getElementById("delete-due");

  const editIdInput = document.getElementById("edit-id");
  const editTitleInput = document.getElementById("edit-title");
  const editCourseInput = document.getElementById("edit-course");
  const editDescriptionInput = document.getElementById("edit-description");
  const editDueInput = document.getElementById("edit-due");

  function formatDateForInput(dateString) {
    if (!dateString) return "";
    try {
      const date = new Date(dateString);
      if (isNaN(date.getTime())) return "";
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    } catch (e) {
      console.error("Error formatting date:", e);
      return "";
    }
  }

  function setFormOpen(open) {
    form?.classList.toggle("hidden", !open);
    hint?.classList.toggle("hidden", open);
  }

  function setEditFormOpen(open, assignmentData = null) {
    if (open && assignmentData) {
      // Fill the form with assignment data
      editIdInput.value = assignmentData.id;
      editTitleInput.value = assignmentData.title;
      editCourseInput.value = assignmentData.course;
      editDescriptionInput.value = assignmentData.description || "";

      const formattedDate = formatDateForInput(assignmentData.due);
      editDueInput.value = formattedDate;

      // Show delete button and set its data
      deleteBtn.classList.remove("hidden");
      deleteBtn.dataset.id = assignmentData.id;
      deleteBtn.dataset.title = assignmentData.title;
      deleteBtn.dataset.course = assignmentData.course;
      deleteBtn.dataset.due = assignmentData.due;
    }

    editForm?.classList.toggle("hidden", !open);
    editHint?.classList.toggle("hidden", open);
  }

  // Add assignment form handlers
  showBtn?.addEventListener("click", () => {
    setFormOpen(true);
    setEditFormOpen(false); // Close edit form if open
  });

  hideBtn?.addEventListener("click", () => setFormOpen(false));

  // Edit assignment form handlers
  editHideBtn?.addEventListener("click", () => setEditFormOpen(false));

  // Click on assignment to edit
  document.querySelectorAll(".assignment-item").forEach((item) => {
    item.addEventListener("click", () => {
      const id = item.dataset.id;
      const title = item.dataset.title;
      const course = item.dataset.course;
      const description = item.dataset.description;
      const due = item.dataset.due;

      setEditFormOpen(true, { id, title, course, description, due });
      setFormOpen(false); // Close add form if open
    });
  });

  // Delete button handler - show modal
  deleteBtn?.addEventListener("click", () => {
    const id = deleteBtn.dataset.id;
    const title = deleteBtn.dataset.title;
    const course = deleteBtn.dataset.course;
    const due = deleteBtn.dataset.due;

    if (id) {
      deleteIdInput.value = id;
      deleteTitleEl.textContent = title || "Untitled";
      deleteCourseEl.textContent = course || "No course code";
      deleteDueEl.textContent = `Due: ${new Date(due).toLocaleDateString(
        "en-CA",
        {
          weekday: "short",
          month: "short",
          day: "numeric",
          year: "numeric",
        },
      )}`;
      deleteModal.classList.remove("hidden");
    }
  });

  // Cancel delete
  cancelDeleteBtn?.addEventListener("click", () => {
    deleteModal.classList.add("hidden");
  });

  // Close modal on outside click
  deleteModal?.addEventListener("click", (e) => {
    if (e.target === deleteModal) {
      deleteModal.classList.add("hidden");
    }
  });

  // If there's a success message after update, keep form closed
  const hasEditSuccess = document.querySelector(
    '[class*="border-emerald-500"]',
  );
  if (hasEditSuccess) {
    setEditFormOpen(false);
  }

  // If there was a form error, keep the form open
  const hasFormError = document.querySelector('[class*="border-york-red"]');
  if (hasFormError) {
    const isEditError = hasFormError.closest("section")?.querySelector("form");
    if (isEditError) {
      setEditFormOpen(true);
    } else {
      setFormOpen(true);
    }
  }


  // Add this to get the current user
  let currentUserId = null;
  
  // Fetch the current user
  fetch('/api/auth/me')
    .then(res => res.json())
    .then(data => {
      currentUserId = data.id;
      console.log('Current user ID:', currentUserId);
    });

</script>
