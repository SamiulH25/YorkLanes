---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { courseDetailPath, fetchCourse } from "../../lib/courses";
import { fetchCourseSections } from "../../lib/course-sections";

export const prerender = false;

const rawCode = Astro.params.code ?? "";
const code = decodeURIComponent(rawCode);

let loadError: string | null = null;
let course: Awaited<ReturnType<typeof fetchCourse>> | null = null;
let sectionGroups: Awaited<ReturnType<typeof fetchCourseSections>>["groups"] = [];

try {
  course = await fetchCourse(code);
  if (course) {
    const sections = await fetchCourseSections({ courseCode: course.code });
    sectionGroups = sections.groups;
  }
} catch (error) {
  loadError = error instanceof Error ? error.message : "Failed to load course";
}

const availableTerms = [...new Set(sectionGroups.map((group) => group.term))];
const defaultTerm = availableTerms[0] ?? "";
const totalSections = sectionGroups.reduce((sum, group) => sum + group.sections.length, 0);

function formatCreditsValue(credits: number | null): string {
  if (credits === null) return "—";
  return Number.isInteger(credits) ? String(credits) : credits.toFixed(1);
}

function formatCreditsLabel(credits: number | null): string {
  if (credits === null) return "Credits";
  return credits === 1 ? "Credit" : "Credits";
}

function groupForTerm(term: string) {
  return sectionGroups.find((group) => group.term === term);
}

function meetingInstructors(section: (typeof sectionGroups)[number]["sections"][number]): string {
  return [...new Set(section.meetings.map((m) => m.instructor).filter(Boolean))].join(", ");
}

function dayShort(day: string): string {
  const map: Record<string, string> = {
    Monday: "Mon",
    Tuesday: "Tue",
    Wednesday: "Wed",
    Thursday: "Thu",
    Friday: "Fri",
    Saturday: "Sat",
    Sunday: "Sun",
  };
  return map[day] ?? day.slice(0, 3);
}
---

<DashboardLayout title={course ? `${course.code} | Courses` : "Course | YorkLanes"} activeNav="courses">
  <Fragment slot="header">
    <div>
      <a href="/courses" class="courses-back">
        <span aria-hidden="true">←</span>
        Catalogue
      </a>
      <h1 class="heading-page">{course?.code ?? "Course"}</h1>
      <p class="mt-0.5 text-sm text-muted">
        {course?.title ?? "Catalogue entry"}
      </p>
    </div>
  </Fragment>

  {
    loadError && (
      <div class="mb-6 rounded-xl border border-accent-soft bg-accent-soft px-4 py-3 text-sm text-secondary">
        {loadError}
      </div>
    )
  }

  {
    course && (
      <article class="course-sheet">
        <header class="course-hero">
          <div class="course-hero__glow" aria-hidden="true" />
          <p class="course-hero__eyebrow">York University catalogue</p>
          <div class="course-hero__topline">
            <h2 class="course-hero__code">{course.code}</h2>
            {
              course.department && (
                <span class="course-hero__dept">{course.department}</span>
              )
            }
          </div>
          <p class="course-hero__title">{course.title}</p>

          <dl class="course-facts">
            <div class="course-fact">
              <dt>{formatCreditsLabel(course.credits)}</dt>
              <dd>{formatCreditsValue(course.credits)}</dd>
            </div>
            <div class="course-fact">
              <dt>Prerequisites</dt>
              <dd>{course.prerequisites.length}</dd>
            </div>
            <div class="course-fact">
              <dt>Sections</dt>
              <dd>{totalSections}</dd>
            </div>
            <div class="course-fact">
              <dt>Terms</dt>
              <dd>{availableTerms.length || "—"}</dd>
            </div>
          </dl>
        </header>

        <div class="course-sheet__body">
          <div class="course-sheet__primary">
            <section class="course-panel course-panel--prose">
              <div class="course-panel__heading">
                <h3 class="course-panel__label">Description</h3>
              </div>
              {
                course.description ? (
                  <p class="course-prose">{course.description}</p>
                ) : (
                  <p class="course-panel__body course-panel__body--muted">
                    No description is listed in the catalogue for this course yet.
                  </p>
                )
              }
            </section>

            <section class="course-panel">
              <div class="course-panel__heading course-panel__heading--split">
                <div>
                  <h3 class="course-panel__label">Sections &amp; timetable</h3>
                  <p class="course-panel__hint">
                    {
                      sectionGroups.length > 0
                        ? `${totalSections} section${totalSections === 1 ? "" : "s"} across ${availableTerms.length} term${availableTerms.length === 1 ? "" : "s"}`
                        : "No scraped timetable data yet"
                    }
                  </p>
                </div>
              </div>

              {
                availableTerms.length > 1 && (
                  <div class="term-tabs" role="tablist" aria-label="Select term">
                    {availableTerms.map((term) => (
                      <button
                        type="button"
                        class:list={["term-tab", term === defaultTerm && "term-tab--active"]}
                        data-term-tab={term}
                        aria-selected={term === defaultTerm}
                      >
                        {term}
                      </button>
                    ))}
                  </div>
                )
              }

              {
                availableTerms.length === 1 && (
                  <p class="course-term-single">{defaultTerm}</p>
                )
              }

              <div id="section-browser" data-default-term={defaultTerm}>
                {
                  availableTerms.length === 0 ? (
                    <div class="course-sections-empty">
                      <p>Section times will show up here after the schedule scraper runs for this course.</p>
                      <a href="/schedule" class="text-brand text-sm font-semibold hover:underline">
                        Open schedule →
                      </a>
                    </div>
                  ) : (
                    availableTerms.map((term) => {
                      const group = groupForTerm(term);
                      const sections = group?.sections ?? [];
                      return (
                        <div
                          class="section-term-panel"
                          data-term={term}
                          role="tabpanel"
                          hidden={term !== defaultTerm}
                        >
                          {sections.length === 0 ? (
                            <p class="mt-4 text-sm text-muted">No sections listed for this term.</p>
                          ) : (
                            <ul class="section-list">
                              {sections.map((section) => (
                                <li class="section-block">
                                  <div class="section-block__head">
                                    <span class="section-block__code">{section.section_code}</span>
                                    {
                                      section.meetings[0]?.delivery_mode && (
                                        <span class="section-mode">{section.meetings[0].delivery_mode}</span>
                                      )
                                    }
                                  </div>
                                  <ul class="section-meetings">
                                    {section.meetings.map((meeting) => (
                                      <li class="section-meeting">
                                        <span class="section-day" title={meeting.day}>
                                          {dayShort(meeting.day)}
                                        </span>
                                        <span class="section-meeting__time">
                                          {meeting.start_time}
                                          <span class="section-meeting__dash">–</span>
                                          {meeting.end_time}
                                        </span>
                                        <span class="section-meeting__place">
                                          {[meeting.campus, meeting.room].filter(Boolean).join(" · ") || "Location TBA"}
                                        </span>
                                      </li>
                                    ))}
                                  </ul>
                                  {
                                    meetingInstructors(section) && (
                                      <p class="section-block__instructor">
                                        <span class="section-block__instructor-label">Instructor</span>
                                        {meetingInstructors(section)}
                                      </p>
                                    )
                                  }
                                </li>
                              ))}
                            </ul>
                          )}
                        </div>
                      );
                    })
                  )
                }
              </div>
            </section>
          </div>

          <aside class="course-rail" aria-label="Course requirements">
            <header class="course-rail__mast">
              <p class="course-rail__kicker">Before you take</p>
              <p class="course-rail__subject">{course.code}</p>
            </header>

            <section class="course-rail__block">
              <h3 class="course-rail__heading">Required first</h3>
              {
                course.prerequisites.length > 0 ? (
                  <ol class="prereq-chain">
                    {
                      course.prerequisites.map((prereq) => (
                        <li class="prereq-chain__step">
                          <span class="prereq-chain__node" aria-hidden="true" />
                          <a href={courseDetailPath(prereq)} class="prereq-chain__link">
                            {prereq}
                          </a>
                        </li>
                      ))
                    }
                    <li class="prereq-chain__step prereq-chain__step--current" aria-current="step">
                      <span class="prereq-chain__node prereq-chain__node--current" aria-hidden="true" />
                      <span class="prereq-chain__current">{course.code}</span>
                    </li>
                  </ol>
                ) : (
                  <p class="course-rail__empty">
                    No prerequisites listed. You can schedule this course without catalogue blockers.
                  </p>
                )
              }
            </section>

            <section class="course-rail__block course-rail__block--plan">
              <h3 class="course-rail__heading">On your degree plan</h3>
              <p class="course-rail__note">
                Slot <span class="course-rail__inline-code">{course.code}</span> into a term and check timing against the graph.
              </p>
              <a href="/plan" class="course-rail__plan-link">
                Open plan editor
                <span aria-hidden="true">↗</span>
              </a>
            </section>
          </aside>
        </div>
      </article>
    )
  }

  {
    !course && !loadError && (
      <div class="courses-empty">
        <div class="courses-empty__mark" aria-hidden="true">?</div>
        <h2 class="mt-3 font-display text-lg font-semibold text-foreground">Course not found</h2>
        <p class="mx-auto mt-2 max-w-md text-sm text-muted">
          That code is not in the catalogue. Go back and try another search.
        </p>
        <a href="/courses" class="btn-york mt-5 inline-flex px-4 py-2.5 text-sm">
          Back to courses
        </a>
      </div>
    )
  }

  {
    availableTerms.length > 1 && (
      <script>
        const tabs = document.querySelectorAll<HTMLButtonElement>("[data-term-tab]");
        const panels = document.querySelectorAll<HTMLElement>(".section-term-panel");

        function selectTerm(term: string) {
          tabs.forEach((tab) => {
            const active = tab.dataset.termTab === term;
            tab.classList.toggle("term-tab--active", active);
            tab.setAttribute("aria-selected", active ? "true" : "false");
          });
          panels.forEach((panel) => {
            panel.hidden = panel.dataset.term !== term;
          });
        }

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const term = tab.dataset.termTab;
            if (term) selectTerm(term);
          });
        });
      </script>
    )
  }
</DashboardLayout>
