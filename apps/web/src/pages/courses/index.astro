---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { courseDetailPath, fetchCourses, fetchDepartments } from "../../lib/courses";

export const prerender = false;

const search = Astro.url.searchParams.get("search")?.trim() ?? "";
const department = Astro.url.searchParams.get("department")?.trim() ?? "";

let loadError: string | null = null;
let courses: Awaited<ReturnType<typeof fetchCourses>>["courses"] = [];
let total = 0;
let departments: string[] = [];

try {
  const [listResult, departmentList] = await Promise.all([
    fetchCourses({ search: search || undefined, department: department || undefined }),
    fetchDepartments(),
  ]);
  courses = listResult.courses;
  total = listResult.total;
  departments = departmentList;
} catch (error) {
  loadError = error instanceof Error ? error.message : "Courses API unavailable";
}

function formatCredits(credits: number | null): string {
  if (credits === null) return "—";
  return Number.isInteger(credits) ? String(credits) : credits.toFixed(1);
}
---

<DashboardLayout title="Courses | YorkLanes" activeNav="courses">
  <Fragment slot="header">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-medium text-york-muted">Catalogue</p>
        <h1 class="heading-page">Course Explorer</h1>
        <p class="mt-0.5 text-sm text-muted">
          {
            `Found ${
              total === 0 ? "no" : total
            } Course${total === 1 ? "" : "s"} in the York Catalogue`
          }
        </p>
      </div>
    </div>
  </Fragment>

  {
    loadError && (
      <div class="mb-6 rounded-xl border border-accent-soft bg-accent-soft px-4 py-3 text-sm text-secondary">
        {loadError}
      </div>
    )
  }

  <form method="get" class="surface mb-6 flex flex-col gap-4 p-4 sm:flex-row sm:items-end sm:p-5">
    <div class="min-w-0 flex-1">
      <label for="course-search" class="label">Search</label>
      <input
        id="course-search"
        name="search"
        type="search"
        value={search}
        placeholder="Code, title, or keywords…"
        class="field-input"
      />
    </div>
    <div class="sm:w-52">
      <label for="course-department" class="label">Department</label>
      <select id="course-department" name="department" class="field-select">
        <option value="">All Departments</option>
        {departments.map((dept) => (
          <option value={dept} selected={dept === department}>
            {dept}
          </option>
        ))}
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="btn-york px-4 py-2.5 text-sm">Search</button>
      {
        (search || department) && (
          <a href="/courses" class="btn-ghost px-4 py-2.5 text-sm">
            Clear
          </a>
        )
      }
    </div>
  </form>

  {
    courses.length === 0 && !loadError ? (
      <div class="empty-state">
        <svg class="mx-auto mb-3 h-9 w-9 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
        </svg>
        <p class="text-sm font-semibold text-foreground">No courses match your filters</p>
        <p class="mx-auto mt-2 max-w-md text-sm text-muted">
          Try a different search term or department, or import courses into the hosted database with{" "}
          <code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-xs dark:bg-white/10">npm run scraper:import</code>.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
        {
          courses.map((course, index) => (
            <a
              href={courseDetailPath(course.code)}
              class="course-card motion-on-scroll surface group"
              style={`transition-delay: ${
                Math.floor(index / 4) < 4
                  ? Math.floor(index / 4) * 100 + (index % 4) * 50
                  : (index % 4) * 50
              }ms;`}
            >
              <div class="flex items-start justify-between gap-2">
                <span class="text-sm font-bold text-brand">{course.code}</span>
                <!--
                  {
                    course.department && (
                      <span class="badge bg-surface-muted text-muted shrink-0">{course.department}</span>
                    )
                  }
                -->
              </div>
              <p class="course-card__title mt-3 flex-1 text-sm font-semibold leading-snug text-foreground group-hover:text-brand">
                {course.title}
              </p>
              <div class="mt-4 flex items-center justify-between gap-2 border-t border-shell pt-3">
                <span class="inline-flex items-center gap-1 rounded-md bg-surface-muted px-1.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-muted">
                  {formatCredits(course.credits)} cr
                </span>
                <span class="course-card__cta" aria-hidden="true">
                  View course →
                </span>
              </div>
            </a>
          ))
        }
      </div>
    )
  }
</DashboardLayout>
