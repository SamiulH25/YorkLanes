---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { fetchCourses, type Course } from "../../lib/courses";

export const prerender = false;

let loadError: string | null = null;
let courses: Course[] = [];

try {
  courses = await fetchCourses() ?? [];
} catch (error) {
  loadError = error instanceof Error ? error.message : "Courses API unavailable";
}

---

<DashboardLayout title="Degree Plan | YorkLanes" activeNav="courses">
  <Fragment slot="header">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-medium text-york-muted">Course Explorer</p>
        <h1 class="heading-page">{"Find Course Details"}</h1>
      </div>
    </div>
  </Fragment>
  
  <div class="surface mx-auto max-w-3xl rounded-2xl p-8 text-center">
    <p style="font-size: 24px; font-weight: bold; margin-bottom: 24px;">Fetched Courses</p>
    {courses.length === 0
      ? <h2>No courses to display.</h2>
      : <table class="w-full table-fixed border border-gray-300 border-collapse">
          <thead>
            <tr>
              <th class="w-40 border border-gray-300 px-3 py-2 text-left">Name</th>
              <th class="border border-gray-300 px-3 py-2 text-left">Title</th>
              <th class="w-24 border border-gray-300 px-3 py-2 text-left">Credits</th>
            </tr>
          </thead>
          <tbody>
            {courses.map((course) => (
              <tr>
                <td class="border border-gray-300 px-3 py-2 text-left">{course.code}</td>
                <td class="border border-gray-300 px-3 py-2 text-left">{course.title}</td>
                <td class="border border-gray-300 px-3 py-2 text-left">{course.credits}</td>
              </tr>
            ))}
          </tbody>
        </table>
    }
  </div>
</DashboardLayout>
