---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { courseDetailPath, fetchCourses, fetchDepartments } from "../../lib/courses";

export const prerender = false;

const search = Astro.url.searchParams.get("search")?.trim() ?? "";
const department = Astro.url.searchParams.get("department")?.trim() ?? "";

let loadError: string | null = null;
let courses: Awaited<ReturnType<typeof fetchCourses>>["courses"] = [];
let total = 0;
let departments: string[] = [];

try {
  const [listResult, departmentList] = await Promise.all([
    fetchCourses({ search: search || undefined, department: department || undefined }),
    fetchDepartments(),
  ]);
  courses = listResult.courses;
  total = listResult.total;
  departments = departmentList;
} catch (error) {
  loadError = error instanceof Error ? error.message : "Courses API unavailable";
}

function formatCredits(credits: number | null): string {
  if (credits === null) return "—";
  return Number.isInteger(credits) ? String(credits) : credits.toFixed(1);
}

function deptHref(dept: string): string {
  const params = new URLSearchParams();
  if (search) params.set("search", search);
  if (dept) params.set("department", dept);
  const query = params.toString();
  return query ? `/courses?${query}` : "/courses";
}

const hasFilters = Boolean(search || department);
const resultLabel =
  total === 0
    ? "No courses"
    : `${total} course${total === 1 ? "" : "s"}`;
---

<DashboardLayout title="Courses | YorkLanes" activeNav="courses">
  <Fragment slot="header">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="label">York catalogue</p>
        <h1 class="heading-page">Courses</h1>
        <p class="mt-1 text-sm text-muted">
          Search by code or title, then open a course for description, prereqs, and sections.
        </p>
      </div>
      {
        !loadError && (
          <p class="courses-count" aria-live="polite">
            <span class="courses-count__value">{total}</span>
            <span class="courses-count__label">listed</span>
          </p>
        )
      }
    </div>
  </Fragment>

  {
    loadError && (
      <div class="mb-6 rounded-xl border border-accent-soft bg-accent-soft px-4 py-3 text-sm text-secondary">
        {loadError}
      </div>
    )
  }

  <form method="get" class="courses-filter" role="search">
    <div class="courses-filter__search">
      <label for="course-search" class="label">Search</label>
      <div class="courses-search-wrap">
        <svg class="courses-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
        </svg>
        <input
          id="course-search"
          name="search"
          type="search"
          value={search}
          placeholder="EECS 3311, software design…"
          class="field-input courses-search-input"
          autocomplete="off"
        />
      </div>
    </div>

    {
      department && (
        <input type="hidden" name="department" value={department} />
      )
    }

    <div class="courses-filter__actions">
      <button type="submit" class="btn-york px-4 py-2.5 text-sm">Search</button>
      {
        hasFilters && (
          <a href="/courses" class="btn-ghost px-4 py-2.5 text-sm">
            Clear
          </a>
        )
      }
    </div>
  </form>

  {
    departments.length > 0 && (
      <nav class="dept-rail" aria-label="Filter by department">
        <a
          href={deptHref("")}
          class:list={["dept-chip", !department && "dept-chip--active"]}
        >
          All
        </a>
        {
          departments.map((dept) => (
            <a
              href={deptHref(dept)}
              class:list={["dept-chip", department === dept && "dept-chip--active"]}
            >
              {dept}
            </a>
          ))
        }
      </nav>
    )
  }

  <div class="courses-toolbar">
    <p class="text-sm text-muted">
      <span class="font-semibold text-foreground">{resultLabel}</span>
      {
        search && (
          <>
            {" "}matching <span class="font-mono text-brand">{search}</span>
          </>
        )
      }
      {
        department && (
          <>
            {" "}in <span class="font-semibold text-foreground">{department}</span>
          </>
        )
      }
    </p>
  </div>

  {
    courses.length === 0 && !loadError ? (
      <div class="courses-empty">
        <div class="courses-empty__mark" aria-hidden="true">∅</div>
        <h2 class="mt-3 font-display text-lg font-semibold text-foreground">No courses match</h2>
        <p class="mx-auto mt-2 max-w-md text-sm text-muted">
          Try another code, keyword, or department
          {hasFilters ? ", or clear filters to browse everything." : "."}
        </p>
        {
          hasFilters && (
            <a href="/courses" class="btn-york mt-5 inline-flex px-4 py-2.5 text-sm">
              Clear filters
            </a>
          )
        }
      </div>
    ) : (
      <div class="course-ledger" role="list">
        <div class="course-ledger__head" aria-hidden="true">
          <span>Code</span>
          <span>Title</span>
          <span>Dept</span>
          <span>Credits</span>
        </div>
        {
          courses.map((course, index) => (
            <a
              href={courseDetailPath(course.code)}
              class="course-ledger__row"
              role="listitem"
              style={`--row-index: ${Math.min(index, 24)}`}
            >
              <span class="course-ledger__code">{course.code}</span>
              <span class="course-ledger__title">{course.title}</span>
              <span class="course-ledger__dept">{course.department ?? "—"}</span>
              <span class="course-ledger__credits">
                <span class="course-ledger__credits-value">{formatCredits(course.credits)}</span>
                <span class="course-ledger__credits-unit">cr</span>
              </span>
              <span class="course-ledger__arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </div>
    )
  }
</DashboardLayout>
