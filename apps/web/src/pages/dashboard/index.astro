---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProgressWidget from "../../components/dashboard/ProgressWidget.astro";
import AssignmentsWidget from "../../components/dashboard/AssignmentsWidget.astro";
import FinanceWidget from "../../components/dashboard/FinanceWidget.astro";
import QuickLinksWidget from "../../components/dashboard/QuickLinksWidget.astro";
import { fetchDashboardSummary } from "../../lib/api";
import { fetchSessionUser } from "../../lib/auth";
import { fetchOnboardingStatus } from "../../lib/onboarding";
import type { DashboardSummary } from "../../types/dashboard";

export const prerender = false;

const cookie = Astro.request.headers.get("cookie");

function guestFinanceSummary(message: string): DashboardSummary["finance"] {
  return {
    balance: 0,
    income: 0,
    expenses: 0,
    currency: "CAD",
    month: new Date().toISOString().slice(0, 7),
    monthSpent: 0,
    monthBudget: 0,
    monthRemaining: 0,
    linked: false,
    message,
  };
}

function guestDashboardSummary(financeMessage: string): DashboardSummary {
  return {
    user: { displayName: "Guest", programme: null, startingYear: null },
    progress: { percentComplete: 0, label: "Sign in to sync degree progress" },
    assignments: { upcoming: [], message: "Sign in to sync assignments, or open Assignments to continue." },
    finance: guestFinanceSummary(financeMessage),
    quickLinks: [
      { label: "Degree Plan", href: "/plan", featureOwner: "Samiul", status: "ready" },
      { label: "Progress Tracker", href: "/progress", featureOwner: "Thor", status: "in-progress" },
      { label: "Course Explorer", href: "/courses", featureOwner: "Jericho", status: "ready" },
      { label: "Schedule Builder", href: "/schedule", featureOwner: "Nabeela", status: "in-progress" },
      { label: "Assignments", href: "/assignments", featureOwner: "Sarah", status: "in-progress" },
      { label: "Finance", href: "/finance", featureOwner: "Taziz", status: "ready" },
    ],
  };
}

let summary: DashboardSummary;
let loadError: string | null = null;
let showOnboardingBanner = false;

const sessionUser = await fetchSessionUser(cookie);

try {
  if (!sessionUser) {
    summary = guestDashboardSummary(
      "Open Finances to track a local draft on this device. Sign in later to sync cloud totals here.",
    );
  } else {
    summary = await fetchDashboardSummary(cookie);
    const onboardingStatus = await fetchOnboardingStatus(cookie);
    showOnboardingBanner = onboardingStatus.signedIn && !onboardingStatus.completed;
  }
} catch (error) {
  loadError = error instanceof Error ? error.message : "Failed to load dashboard";
  summary = guestDashboardSummary(
    "Open Finances to track a local draft, or start the API and sign in to sync.",
  );
  if (sessionUser) {
    summary = {
      ...summary,
      user: {
        displayName: sessionUser.displayName,
        programme: null,
        startingYear: null,
      },
    };
  }
}

const today = new Date().toLocaleDateString("en-CA", {
  weekday: "long",
  month: "long",
  day: "numeric",
});
---

<DashboardLayout title="Dashboard | YorkLanes" activeNav="dashboard">
  <Fragment slot="header">
    <div>
      <p class="text-xs font-medium text-muted">{today}</p>
      <h1 class="heading-page">Hey, {summary.user.displayName}</h1>
      <p class="mt-0.5 text-sm text-muted">
        {
          summary.user.programme
            ? `${summary.user.programme} · Class of ${(summary.user.startingYear ?? 0) + 4}`
            : "Set up your programme to get started"
        }
      </p>
    </div>
  </Fragment>

  {
    loadError && (
      <div class="mb-6 rounded-xl border border-accent-soft bg-accent-soft px-4 py-3 text-sm text-secondary">
        API offline: {loadError}. Run <code class="rounded bg-black/5 px-1.5 py-0.5 font-mono text-xs dark:bg-white/10">npm run start:dev</code>
      </div>
    )
  }

  {
    showOnboardingBanner && (
      <div class="mb-6 surface-elevated flex flex-wrap items-center justify-between gap-4 border border-brand-soft bg-brand-subtle p-5">
        <div>
          <p class="text-sm font-semibold text-foreground">Finish setting up YorkLanes</p>
          <p class="mt-0.5 text-sm text-muted">
            Tell us your programme and import your checklist to build your degree plan.
          </p>
        </div>
        <a href="/onboarding" class="btn-york shrink-0">Continue setup</a>
      </div>
    )
  }

  <div class="mb-6 surface-elevated flex flex-wrap items-center justify-between gap-4 p-5">
    <div>
      <p class="text-sm font-medium text-muted">Status</p>
      <p class="mt-0.5 text-sm text-secondary">
        The degree plan is ready. Courses, schedule, and the other tabs are still being built.
      </p>
    </div>
    <a href="/plan" class="btn-york shrink-0">Open degree plan</a>
  </div>

  <div class="grid gap-5 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <ProgressWidget progress={summary.progress} />
    </div>
    <div class="flex flex-col gap-5 lg:col-span-7">
      <AssignmentsWidget assignments={summary.assignments} />
      <FinanceWidget finance={summary.finance} />
    </div>
    <div class="lg:col-span-12">
      <QuickLinksWidget links={summary.quickLinks} />
    </div>
  </div>
</DashboardLayout>

