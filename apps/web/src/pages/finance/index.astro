---
/** Finance module — Taziz. Guide: docs/tasks/finance.md */
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { EXPENSE_CATEGORIES, INCOME_CATEGORIES } from "../../lib/finance-categories";

export const prerender = false;
---

<DashboardLayout title="Finance | YorkLanes" activeNav="finance">
  <Fragment slot="header">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-medium text-york-muted">Finance</p>
        <h1 class="heading-page">Student finances</h1>
      </div>
      <p data-finance-mode class="rounded-full bg-york-gold/15 px-3 py-1 text-xs font-semibold text-york-gold">
        Local draft
      </p>
    </div>
  </Fragment>

  <div
    data-finance-root
    data-expense-categories={EXPENSE_CATEGORIES.join("|")}
    data-income-categories={INCOME_CATEGORIES.join("|")}
    class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_24rem]"
  >
    <aside
      data-finance-signin
      hidden
      class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-york-gold/40 bg-york-gold/10 px-4 py-3 xl:col-span-2"
    >
      <div>
        <p class="text-sm font-semibold text-york-black dark:text-white">
          Sign in to save finance data to your account
        </p>
        <p class="mt-1 text-xs text-york-muted">
          Guests keep a local draft on this device. Signed-in users sync to the cloud and only see their own rows.
        </p>
      </div>
      <a href="/login?returnTo=/finance" class="btn-york shrink-0 px-4 py-2 text-sm">Sign in</a>
    </aside>

    <section class="grid gap-4 md:grid-cols-3 xl:col-span-2">
      <article class="surface p-5">
        <p class="label">Balance</p>
        <p data-finance-balance class="mt-2 font-display text-3xl font-semibold text-york-black dark:text-white">
          $0.00
        </p>
      </article>
      <article class="surface p-5">
        <p class="label">Income</p>
        <p data-finance-income class="mt-2 font-display text-3xl font-semibold text-emerald-700 dark:text-emerald-300">
          $0.00
        </p>
      </article>
      <article class="surface p-5">
        <p class="label">Expenses</p>
        <p data-finance-expenses class="mt-2 font-display text-3xl font-semibold text-york-red">
          $0.00
        </p>
      </article>
    </section>

    <section class="surface p-5 xl:col-span-2">
      <div class="grid gap-5 lg:grid-cols-[18rem_minmax(0,1fr)]">
        <div>
          <p class="label">Monthly budget</p>
          <h2 class="heading-widget mt-1">Budget vs spent</h2>
          <form data-finance-budget-form class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            <label class="block">
              <span class="label">Month</span>
              <input
                data-finance-month
                required
                name="month"
                type="month"
                class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
              />
            </label>
            <label class="block">
              <span class="label">Budget</span>
              <input
                data-finance-budget-input
                required
                name="budget"
                type="number"
                min="0"
                step="0.01"
                placeholder="1200.00"
                class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
              />
            </label>
            <button type="submit" class="btn-york w-full">Save budget</button>
          </form>
        </div>

        <div class="grid content-start gap-4 sm:grid-cols-3">
          <article class="surface-muted p-4">
            <p class="label">Budget</p>
            <p data-finance-budget-value class="mt-2 font-display text-2xl font-semibold text-york-black dark:text-white">
              $0.00
            </p>
          </article>
          <article class="surface-muted p-4">
            <p class="label">Spent</p>
            <p data-finance-month-spent class="mt-2 font-display text-2xl font-semibold text-york-red">
              $0.00
            </p>
          </article>
          <article class="surface-muted p-4">
            <p class="label">Remaining</p>
            <p data-finance-budget-remaining class="mt-2 font-display text-2xl font-semibold text-emerald-700 dark:text-emerald-300">
              $0.00
            </p>
          </article>
          <div class="sm:col-span-3">
            <div class="h-3 overflow-hidden rounded-full bg-york-cream dark:bg-york-graphite">
              <div data-finance-budget-bar class="h-full rounded-full bg-york-red transition-[width] duration-200" style="width: 0%"></div>
            </div>
            <p data-finance-budget-status class="mt-2 text-xs text-york-muted">Set a monthly budget to track spending.</p>
            <p
              data-finance-budget-alert
              hidden
              class="mt-3 rounded-xl border px-3 py-2 text-xs font-semibold leading-relaxed"
            ></p>
          </div>
        </div>
      </div>
    </section>

    <section class="surface p-5 xl:row-span-2">
      <div class="widget-header">
        <div>
          <p class="label">Entry form</p>
          <h2 data-finance-form-title class="heading-widget mt-1">Log money</h2>
        </div>
        <button type="button" data-finance-cancel-edit class="btn-ghost hidden px-3 py-2 text-xs">
          Cancel edit
        </button>
      </div>

      <form data-finance-form class="mt-5 space-y-4">
        <input data-finance-edit-id type="hidden" name="entryId" value="" />
        <div class="grid grid-cols-2 gap-2 rounded-xl bg-york-cream/70 p-1 dark:bg-york-graphite">
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="kind" value="expense" checked />
            <span class="block rounded-lg px-3 py-2 text-center text-sm font-semibold text-york-muted transition peer-checked:bg-white peer-checked:text-york-red peer-checked:shadow-sm dark:peer-checked:bg-york-panel dark:peer-checked:text-white">
              Expense
            </span>
          </label>
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="kind" value="income" />
            <span class="block rounded-lg px-3 py-2 text-center text-sm font-semibold text-york-muted transition peer-checked:bg-white peer-checked:text-emerald-700 peer-checked:shadow-sm dark:peer-checked:bg-york-panel dark:peer-checked:text-emerald-300">
              Income
            </span>
          </label>
        </div>

        <label class="block">
          <span class="label">Label</span>
          <input
            data-finance-label
            required
            name="label"
            type="text"
            maxlength="80"
            placeholder="Tuition payment"
            class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
          />
        </label>

        <div class="grid gap-3 sm:grid-cols-3">
          <label class="block">
            <span class="label">Amount</span>
            <input
              required
              name="amount"
              type="number"
              min="0.01"
              step="0.01"
              placeholder="25.00"
              class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
            />
          </label>
          <label class="block">
            <span class="label">Category</span>
            <select
              data-finance-category
              name="category"
              class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
            >
              {EXPENSE_CATEGORIES.map((category) => <option value={category}>{category}</option>)}
            </select>
            <span class="mt-1 block text-xs text-york-muted">York student categories (OSAP, tuition, rent, and more).</span>
          </label>
          <label class="block">
            <span class="label">Date</span>
            <input
              name="occurredOn"
              type="date"
              class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
            />
          </label>
          <label class="block">
            <span class="label">Recurrence</span>
            <select
              data-finance-recurrence
              name="recurrence"
              class="mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 disabled:cursor-not-allowed disabled:opacity-60 dark:border-white/10 dark:bg-york-graphite dark:text-white"
            >
              <option value="none">One-time</option>
              <option value="weekly">Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
            <span data-finance-recurrence-hint class="mt-1 block text-xs text-york-muted">
              Log each occurrence when it is due.
            </span>
          </label>
        </div>

        <button data-finance-submit type="submit" class="btn-york w-full">Add entry</button>
      </form>
    </section>

    <section class="surface p-5 xl:col-span-2">
      <div class="widget-header">
        <div>
          <p class="label">Recurring</p>
          <h2 class="heading-widget mt-1">Due this month</h2>
        </div>
        <p data-finance-due-month class="text-xs font-semibold text-york-muted"></p>
      </div>
      <div data-finance-due class="mt-5 space-y-3"></div>
      <p data-finance-due-empty class="empty-state mt-5 text-sm text-york-muted">
        No recurring income or expenses due in the selected month.
      </p>
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:col-span-2">
      <section class="surface p-5">
        <div class="widget-header">
          <div>
            <p class="label">Breakdown</p>
            <h2 class="heading-widget mt-1">Expenses by category</h2>
          </div>
        </div>
        <div data-finance-chart class="mt-5 space-y-3"></div>
        <p data-finance-chart-empty class="empty-state mt-5 text-sm text-york-muted">No expenses logged yet.</p>
      </section>

      <section class="surface p-5">
        <div class="widget-header">
          <div>
            <p class="label">Breakdown</p>
            <h2 class="heading-widget mt-1">Income by category</h2>
          </div>
        </div>
        <div data-finance-income-chart class="mt-5 space-y-3"></div>
        <p data-finance-income-chart-empty class="empty-state mt-5 text-sm text-york-muted">No income logged yet.</p>
      </section>
    </section>

    <section class="surface p-5">
      <div class="widget-header">
        <div>
          <p class="label">Monthly review</p>
          <h2 class="heading-widget mt-1">Income vs expenses</h2>
        </div>
        <button type="button" data-finance-export class="btn-ghost px-3 py-2 text-xs">Export CSV</button>
      </div>
      <label class="mt-5 flex items-center gap-2 text-sm font-semibold text-york-muted">
        <input
          data-finance-month-filter
          type="checkbox"
          class="h-4 w-4 rounded border-york-stone text-york-red focus:ring-york-red"
        />
        Show selected month only
      </label>
      <div data-finance-trend class="mt-5 space-y-3"></div>
      <p data-finance-trend-empty class="empty-state mt-5 text-sm text-york-muted">No monthly activity yet.</p>
    </section>

    <section class="surface p-5">
      <div class="widget-header">
        <div>
          <p class="label">Recent</p>
          <h2 class="heading-widget mt-1">Entries</h2>
        </div>
        <button type="button" data-finance-clear class="btn-ghost px-3 py-2 text-xs">Clear local</button>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto]">
        <label class="block min-w-0">
          <span class="sr-only">Search entries</span>
          <input
            data-finance-search
            type="search"
            placeholder="Search label or category"
            class="w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white"
          />
        </label>
        <div
          class="grid grid-cols-3 gap-1 rounded-xl bg-york-cream/70 p-1 dark:bg-york-graphite"
          role="group"
          aria-label="Filter by kind"
        >
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="listKind" value="all" data-finance-kind-filter checked />
            <span class="block rounded-lg px-3 py-2 text-center text-xs font-semibold text-york-muted transition peer-checked:bg-white peer-checked:text-york-black peer-checked:shadow-sm dark:peer-checked:bg-york-panel dark:peer-checked:text-white">
              All
            </span>
          </label>
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="listKind" value="expense" data-finance-kind-filter />
            <span class="block rounded-lg px-3 py-2 text-center text-xs font-semibold text-york-muted transition peer-checked:bg-white peer-checked:text-york-red peer-checked:shadow-sm dark:peer-checked:bg-york-panel dark:peer-checked:text-white">
              Expense
            </span>
          </label>
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="listKind" value="income" data-finance-kind-filter />
            <span class="block rounded-lg px-3 py-2 text-center text-xs font-semibold text-york-muted transition peer-checked:bg-white peer-checked:text-emerald-700 peer-checked:shadow-sm dark:peer-checked:bg-york-panel dark:peer-checked:text-emerald-300">
              Income
            </span>
          </label>
        </div>
      </div>

      <div data-finance-empty class="empty-state mt-5 text-sm text-york-muted">
        No entries yet.
      </div>
      <ul data-finance-list class="mt-5 divide-y divide-york-stone/50 dark:divide-white/10"></ul>
    </section>
  </div>

  <script>
    import "../../scripts/finance.ts";
  </script>
</DashboardLayout>
