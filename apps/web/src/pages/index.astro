---
import BaseLayout from "../layouts/BaseLayout.astro";
import YorkMark from "../components/YorkMark.astro";
import SettingsMenu from "../components/SettingsMenu.astro";
import { fetchSessionUser } from "../lib/auth";

export const prerender = false;

const cookie = Astro.request.headers.get("cookie");
const sessionUser = await fetchSessionUser(cookie);

const features = [
  {
    title: "Upload your checklist",
    body: "Download the pdf or docx from your faculty page and upload it. The parser grabs course codes, credits, and how things are grouped by year.",
  },
  {
    title: "Sort courses by term",
    body: "Once your plan loads you can move courses between terms and see prereqs on the graph instead of ctrl+f-ing a 40 page document.",
  },
  {
    title: "Use the rest of the app",
    body: "Assignments, schedule, finance, progress, all tied to the same account. Some of that is still getting built but you need to be signed in either way.",
  },
];
---

<BaseLayout title="YorkLanes | degree planning for York">
  <div class="hero-shell">
    <header class="hero-header">
      <a href="/" class="flex min-w-0 items-center gap-2 transition-opacity hover:opacity-90">
        <div class="rounded-xl bg-york-red/10 p-1 dark:bg-york-red/15">
          <YorkMark class="h-8 w-8" />
        </div>
        <div class="min-w-0">
          <p class="truncate font-display text-base font-semibold leading-tight text-york-black dark:text-white">
            YorkLanes
          </p>
          <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-york-red">York University</p>
        </div>
      </a>

      <nav class="flex items-center gap-2 sm:gap-3">
        <SettingsMenu showAccount signedIn={Boolean(sessionUser)} displayName={sessionUser?.displayName} />
        {
          sessionUser ? (
            <a href="/dashboard" class="btn-york px-3 py-2 text-sm sm:px-4">
              Dashboard
            </a>
          ) : (
            <a href="/login" class="btn-york px-3 py-2 text-sm sm:px-4">
              Sign in
            </a>
          )
        }
      </nav>
    </header>

    <main class="hero-main">
      <section class="hero-copy animate-slide-up">
        <p class="label">Unofficial student project</p>
        <h1 class="mt-3 font-display text-4xl font-semibold leading-[1.1] tracking-tight text-york-black dark:text-white sm:text-5xl lg:text-6xl">
          Degree planning without reopening the same checklist every week
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-stone-600 dark:text-stone-300 sm:text-lg">
          YorkLanes reads your faculty checklist and maps courses onto terms. You need an account to
          do anything here: import a file, save a plan, or open the dashboard.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {
            sessionUser ? (
              <a href="/dashboard" class="btn-york px-6 py-3">Open dashboard</a>
            ) : (
              <>
                <a href="/login" class="btn-york px-6 py-3">Sign in with Google</a>
                <a href="/login?returnTo=%2Fonboarding" class="btn-ghost px-6 py-3">New here? Set up your account</a>
              </>
            )
          }
        </div>

        <p class="mt-6 text-sm text-york-muted">
          {
            sessionUser
              ? `Logged in as ${sessionUser.displayName}.`
              : "No guest mode. Sign in first, then upload your checklist from the dashboard or onboarding."
          }
        </p>
      </section>

      <section class="hero-features animate-slide-up" style="animation-delay: 80ms">
        <div class="grid gap-4 sm:grid-cols-3">
          {
            features.map((feature, index) => (
              <article class="hero-feature-card">
                <div class="icon-badge bg-york-red/10 text-york-red">
                  {
                    index === 0 ? (
                      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                      </svg>
                    ) : index === 1 ? (
                      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                      </svg>
                    ) : (
                      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                      </svg>
                    )
                  }
                </div>
                <h2 class="mt-3 font-display text-lg font-semibold text-york-black dark:text-white">
                  {feature.title}
                </h2>
                <p class="mt-2 text-sm leading-relaxed text-york-muted">{feature.body}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <footer class="hero-footer">
      <p class="text-xs text-york-muted">
        Side project. Not affiliated with York University.
      </p>
    </footer>
  </div>
</BaseLayout>
