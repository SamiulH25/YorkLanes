---
/** Auth UI — Google OAuth via API session. Setup: docs/tasks/auth.md */
import BaseLayout from "../layouts/BaseLayout.astro";
import YorkMark from "../components/YorkMark.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { fetchAuthStatus, fetchSessionUser, googleSignInUrl } from "../lib/auth";

export const prerender = false;

const cookie = Astro.request.headers.get("cookie");
const existingUser = await fetchSessionUser(cookie);
if (existingUser) {
  return Astro.redirect("/dashboard");
}

const { oauthEnabled, message: authNote } = await fetchAuthStatus();
const signInUrl = googleSignInUrl();

const errorMessages: Record<string, string> = {
  "oauth-not-configured": "Google sign-in is not configured on the API yet.",
  "oauth-start-failed": "Could not start Google sign-in.",
  "oauth-state-mismatch": "Sign-in session expired. Try again.",
  "oauth-callback-failed": "Google sign-in failed. Check API logs.",
  "oauth-denied": "Google sign-in was cancelled.",
};

const errorCode = Astro.url.searchParams.get("error");
const errorNote = errorCode ? errorMessages[errorCode] : null;
---

<BaseLayout title="Sign In | YorkLanes">
  <div class="relative flex min-h-screen flex-col">
    <div class="absolute right-6 top-6">
      <ThemeToggle />
    </div>

    <div class="flex flex-1 flex-col items-center justify-center px-4 py-12">
      <div class="absolute inset-0 bg-york-hero pointer-events-none"></div>

      <div class="surface relative w-full max-w-md rounded-2xl p-8">
        <div class="mb-6 flex items-center gap-3">
          <YorkMark class="h-10 w-[2.5rem]" />
          <div>
            <h1 class="font-display text-2xl font-semibold text-york-black dark:text-white">YorkLanes</h1>
            <p class="text-xs font-medium uppercase tracking-widest text-york-red">York University</p>
          </div>
        </div>

        <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-300">
          Your degree, schedule, and student life in one place. Built for York students, not spreadsheets.
        </p>

        {
          oauthEnabled ? (
            <a href={signInUrl} class="btn-york mt-8 w-full">
              <svg class="h-4 w-4" viewBox="0 0 24 24">
                <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              Continue with Google
            </a>
          ) : (
            <button type="button" disabled class="btn-york mt-8 w-full cursor-not-allowed opacity-60">
              Continue with Google
            </button>
          )
        }

        {errorNote && <p class="mt-4 text-center text-xs text-york-red">{errorNote}</p>}
        <p class="mt-4 text-center text-xs text-york-muted">{authNote}</p>
      </div>

      <p class="relative mt-8 text-center text-xs text-york-muted">
        EECS4314 · Group 7 · York University
      </p>
    </div>
  </div>
</BaseLayout>
