---
/**
 * Login page placeholder.
 *
 * EXPAND HERE (Google OAuth 2.0):
 * 1. Implement OAuth flow in apps/api/src/auth/ and apps/api/src/routes/auth.ts
 * 2. Change the button below to redirect to GET /auth/google on the API
 * 3. Handle callback and set session cookie
 * 4. Redirect authenticated users to /dashboard (or /onboarding if no programme set)
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sign In | YorkLanes">
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
      <h1 class="text-2xl font-bold text-gray-900">YorkLanes</h1>
      <p class="mt-2 text-sm text-york-muted">
        Sign in to save your course plans, schedules, and assignments.
      </p>

      <!-- TODO: href="/auth/google" on API once OAuth is implemented -->
      <a
        href="/dashboard"
        class="mt-6 flex w-full items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-700 shadow-sm transition-colors hover:bg-gray-50"
      >
        Sign in with Google (not yet configured)
      </a>

      <p class="mt-4 text-center text-xs text-york-muted">
        OAuth will use Google OAuth 2.0 via Passport.js or Firebase Auth.
      </p>
    </div>
  </div>
</BaseLayout>
