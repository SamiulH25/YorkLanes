---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Onboarding | YorkLanes" activeNav="onboarding">
  <Fragment slot="header">
    <div>
      <p class="text-xs font-medium text-york-muted">First time here</p>
      <h1 class="heading-page">Set up your degree</h1>
      <p class="mt-0.5 text-sm text-york-muted">Tell us your programme so we can build your plan</p>
    </div>
  </Fragment>

  <div class="surface max-w-lg rounded-2xl p-8">
    <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-300">
      After sign-in, new students land here until they pick a programme and start year.
    </p>

    <form class="mt-6 space-y-5">
      <div>
        <label class="mb-1.5 block text-sm font-medium text-york-black dark:text-white">Programme</label>
        <select disabled class="w-full rounded-xl border border-york-stone/80 bg-york-cream/50 px-3 py-2.5 text-sm dark:border-white/15 dark:bg-york-navy/50">
          <option>BSc Computer Science</option>
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-sm font-medium text-york-black dark:text-white">Starting year</label>
        <select disabled class="w-full rounded-xl border border-york-stone/80 bg-york-cream/50 px-3 py-2.5 text-sm dark:border-white/15 dark:bg-york-navy/50">
          <option>2025</option>
        </select>
      </div>
      <button type="button" disabled class="btn-york opacity-40">
        Save and continue
      </button>
    </form>
  </div>
</DashboardLayout>
