---
import OnboardingLayout from "../../layouts/OnboardingLayout.astro";
import { fetchFaculties } from "../../lib/plans";
import { fetchSessionUser, googleSignInUrl } from "../../lib/auth";
import { fetchOnboardingStatus } from "../../lib/onboarding";

export const prerender = false;

const cookie = Astro.request.headers.get("cookie");
const stepParam = Number(Astro.url.searchParams.get("step") ?? "1");
const step = Number.isInteger(stepParam) && stepParam >= 1 && stepParam <= 4 ? stepParam : 1;

const sessionUser = await fetchSessionUser(cookie);
const onboardingStatus = await fetchOnboardingStatus(cookie);

if (onboardingStatus.completed && step < 4) {
  return Astro.redirect("/dashboard");
}

if (sessionUser && step === 3) {
  return Astro.redirect("/onboarding?step=4");
}

if (!sessionUser && step === 4) {
  return Astro.redirect("/onboarding?step=3");
}

let faculties: Awaited<ReturnType<typeof fetchFaculties>> = [];
let facultiesError: string | null = null;

try {
  faculties = await fetchFaculties();
} catch (error) {
  facultiesError = error instanceof Error ? error.message : "Could not load faculties";
}

const currentYear = new Date().getFullYear();
const yearOptions = Array.from({ length: 8 }, (_, index) => currentYear - 3 + index);

const signInUrl = googleSignInUrl("/onboarding?step=4");
const inputClass =
  "mt-2 w-full rounded-xl border border-york-stone/60 bg-white/80 px-3 py-2.5 text-sm text-york-black outline-none transition focus:border-york-red focus:ring-2 focus:ring-york-red/20 dark:border-white/10 dark:bg-york-graphite dark:text-white";

const setupSteps = [
  {
    title: "Pick your programme",
    body: "Faculty, major, and start year so import is pre-filled.",
  },
  {
    title: "Sign in with Google",
    body: "Required before you can import or open the dashboard.",
  },
  {
    title: "Upload your checklist",
    body: "Pdf or docx from your faculty page. We parse it into a term plan.",
  },
];
---

<OnboardingLayout step={step}>
  {
    step === 1 && (
      <div>
        <p class="label">Setup</p>
        <h1 class="mt-1 font-display text-2xl font-semibold text-york-black dark:text-white sm:text-3xl">
          Get your account set up
        </h1>
        <p class="mt-3 text-sm leading-relaxed text-stone-600 dark:text-stone-300">
          YorkLanes needs you signed in before you can import a checklist or open the dashboard.
          This takes a few minutes if you have your programme details handy.
        </p>

        <ul class="mt-6 space-y-3">
          {
            setupSteps.map((item, index) => (
              <li class="flex gap-3 rounded-xl surface-muted px-4 py-3">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-york-red/10 text-xs font-bold text-york-red">
                  {index + 1}
                </span>
                <div>
                  <p class="text-sm font-semibold text-york-black dark:text-white">{item.title}</p>
                  <p class="mt-0.5 text-xs text-york-muted">{item.body}</p>
                </div>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/onboarding?step=2" class="btn-york">Continue</a>
          <a href="/" class="btn-ghost">Back to home</a>
        </div>
      </div>
    )
  }

  {
    step === 2 && (
      <div>
        <p class="label">Your programme</p>
        <h1 class="mt-1 font-display text-2xl font-semibold text-york-black dark:text-white sm:text-3xl">
          What are you studying?
        </h1>
        <p class="mt-3 text-sm text-york-muted">
          Used to pre-fill checklist import. You can fix it later if the parser gets something wrong.
        </p>

        {
          facultiesError && (
            <p class="mt-4 rounded-lg border border-york-gold/40 bg-york-gold/10 px-3 py-2 text-sm text-stone-700 dark:text-stone-200">
              Faculty list is down ({facultiesError}). You can still type your programme and continue.
            </p>
          )
        }

        <form id="onboarding-programme-form" class="mt-6 space-y-4">
          <label class="block">
            <span class="label">Faculty</span>
            <select id="facultyKey" name="facultyKey" required class={inputClass}>
              <option value="">Select faculty...</option>
              {faculties.map((faculty) => (
                <option value={faculty.key}>{faculty.name}</option>
              ))}
            </select>
          </label>

          <label class="block">
            <span class="label">Programme name</span>
            <input
              type="text"
              id="programmeName"
              name="programmeName"
              required
              class={inputClass}
              placeholder="BSc Honours Computer Science"
            />
          </label>

          <label class="block">
            <span class="label">Starting year</span>
            <select id="startingYear" name="startingYear" required class={inputClass}>
              {yearOptions.map((year) => (
                <option value={year} selected={year === currentYear}>
                  {year}
                </option>
              ))}
            </select>
          </label>

          <div class="flex flex-wrap gap-3 pt-2">
            <a href="/onboarding?step=1" class="btn-ghost">Back</a>
            <button type="submit" class="btn-york">Continue</button>
          </div>
        </form>
      </div>
    )
  }

  {
    step === 3 && (
      <div>
        <p class="label">Account</p>
        <h1 class="mt-1 font-display text-2xl font-semibold text-york-black dark:text-white sm:text-3xl">
          Sign in to continue
        </h1>
        <p class="mt-3 text-sm leading-relaxed text-stone-600 dark:text-stone-300">
          You need a YorkLanes account to import a checklist or use the dashboard. Sign in with
          Google and we will bring you back here for the upload step.
        </p>

        <div class="mt-8">
          <a href={signInUrl} class="btn-york inline-flex w-full justify-center sm:w-auto">
            Sign in with Google
          </a>
        </div>

        <a href="/onboarding?step=2" class="mt-6 inline-block text-sm font-medium text-york-muted hover:text-york-red">
          Back
        </a>
      </div>
    )
  }

  {
    step === 4 && (
      <div>
        <p class="label">Last step</p>
        <h1 class="mt-1 font-display text-2xl font-semibold text-york-black dark:text-white sm:text-3xl">
          Import your checklist
        </h1>
        <p class="mt-3 text-sm text-york-muted">
          Download the pdf or docx from your faculty site, then upload it on the next page. The
          parser builds your term plan from that file.
        </p>

        <div id="onboarding-summary" class="mt-6 rounded-xl surface-muted px-4 py-3 text-sm hidden">
          <p class="label">Your details</p>
          <p id="summary-programme" class="mt-1 font-medium text-york-black dark:text-white" />
          <p id="summary-faculty" class="mt-0.5 text-xs text-york-muted" />
        </div>

        <p id="onboarding-finish-error" class="mt-4 hidden rounded-lg border border-york-red/30 bg-york-red/5 px-3 py-2 text-sm text-york-red" />

        <div class="mt-8 flex flex-wrap gap-3">
          <button type="button" id="onboarding-finish-btn" class="btn-york">
            Go to checklist import
          </button>
        </div>

        <a href="/onboarding?step=2" class="mt-6 inline-block text-sm font-medium text-york-muted hover:text-york-red">
          Back
        </a>
      </div>
    )
  }

  <div
    id="onboarding-boot"
    class="hidden"
    data-step={step}
    data-signed-in={sessionUser ? "true" : "false"}
    data-faculties={JSON.stringify(faculties.map((f) => ({ key: f.key, name: f.name })))}
  />

  <script>
    import { initOnboardingPage } from "../../scripts/onboarding.ts";

    const boot = document.getElementById("onboarding-boot");
    if (boot) {
      initOnboardingPage({
        step: Number(boot.dataset.step ?? "1"),
        signedIn: boot.dataset.signedIn === "true",
        faculties: JSON.parse(boot.dataset.faculties ?? "[]"),
      });
    }
  </script>
</OnboardingLayout>
