---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { fetchMyPlan, fetchPlan } from "../../lib/plans";
import type { PlanCourse, PlanTerm } from "../../types/plan";

// Must be server-rendered so ?id= query param and plan data resolve per request.
export const prerender = false;

const cookie = Astro.request.headers.get("cookie");
const planIdParam = Astro.url.searchParams.get("id");

let plan = null;
let loadError: string | null = null;

if (planIdParam) {
  try {
    plan = await fetchPlan(planIdParam, cookie);
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Failed to load plan";
  }
} else {
  try {
    plan = await fetchMyPlan(cookie);
    if (plan) {
      return Astro.redirect(`/plan?id=${plan.id}`);
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Failed to load plan";
  }
}

const planId = plan?.id ?? planIdParam ?? "";

type Season = "fall" | "winter" | "summer" | "other";

interface YearColumn {
  checklistYear: number;
  academicYear: number;
  fall: PlanTerm | null;
  winter: PlanTerm | null;
  summer: PlanTerm | null;
}

function normalizeSeason(session: string): Season {
  const value = session.toLowerCase();
  if (value.includes("fall") || value.includes("autumn")) return "fall";
  if (value.includes("winter")) return "winter";
  if (value.includes("summer")) return "summer";
  return "other";
}

function groupTermsByYear(terms: PlanTerm[]): YearColumn[] {
  const byYear = new Map<number, YearColumn>();

  for (const term of terms) {
    const key = term.checklist_year;
    let column = byYear.get(key);
    if (!column) {
      column = {
        checklistYear: key,
        academicYear: term.academic_year,
        fall: null,
        winter: null,
        summer: null,
      };
      byYear.set(key, column);
    }

    const season = normalizeSeason(term.session);
    if (season === "fall") column.fall = term;
    else if (season === "winter") column.winter = term;
    else if (season === "summer") column.summer = term;
    else if (!column.fall) column.fall = term;
    else if (!column.winter) column.winter = term;
    else column.summer = term;
  }

  return [...byYear.values()].sort((a, b) => a.checklistYear - b.checklistYear);
}

function termCredits(term: PlanTerm): number {
  return term.courses.reduce((sum, course) => sum + (course.credits ?? 0), 0);
}

function courseCount(term: PlanTerm): number {
  return term.courses.filter((course) => course.entry_kind !== "stub").length;
}

function academicSpan(year: number): string {
  return `${year}–${String(year + 1).slice(-2)}`;
}

interface SeasonSlot {
  key: Season;
  term: PlanTerm | null;
  label: string;
}

function seasonSlotsForYear(year: YearColumn, includeSummer: boolean): SeasonSlot[] {
  const seasons: SeasonSlot[] = [
    { key: "fall", term: year.fall, label: "Fall" },
    { key: "winter", term: year.winter, label: "Winter" },
  ];
  if (includeSummer) {
    seasons.push({ key: "summer", term: year.summer, label: "Summer" });
  }
  return seasons;
}

const yearColumns = plan ? groupTermsByYear(plan.terms) : [];
const showSummerRow = yearColumns.some((column) => column.summer !== null);
---

<DashboardLayout title="Degree Plan | YorkLanes" activeNav="plan" collapseSidebar>
  <Fragment slot="header">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-medium text-york-muted">Degree plan editor</p>
        <h1 class="heading-page">{plan?.programme_name ?? "Your degree plan"}</h1>
        {
          plan && (
            <p class="mt-0.5 text-sm text-york-muted">
              Started {plan.starting_year} · {yearColumns.length} year{yearColumns.length === 1 ? "" : "s"} · from {plan.source_filename}
            </p>
          )
        }
      </div>
      <a href="/plan/setup" class="btn-york">Import new checklist</a>
    </div>
  </Fragment>

  {
    !planId && (
      <div class="surface mx-auto max-w-lg rounded-2xl p-8 text-center">
        <p class="text-xs font-medium uppercase tracking-widest text-york-red">Get started</p>
        <h2 class="mt-2 font-display text-xl font-semibold text-york-black dark:text-white">Import your degree checklist</h2>
        <p class="mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-300">
          Download the checklist from your faculty site, upload it on the next screen, and we parse your courses into a term plan.
        </p>
        <ol class="mt-6 space-y-2 text-left text-sm text-stone-600 dark:text-stone-300">
          <li><span class="font-semibold text-york-black dark:text-white">1.</span> Choose your faculty and programme details</li>
          <li><span class="font-semibold text-york-black dark:text-white">2.</span> Download the PDF or DOCX checklist</li>
          <li><span class="font-semibold text-york-black dark:text-white">3.</span> Upload the file and we build your plan</li>
        </ol>
        <a href="/plan/setup" class="btn-york mt-6 inline-flex">Go to checklist import</a>
      </div>
    )
  }

  {
    loadError && (
      <div class="mb-6 rounded-xl border border-york-gold/40 bg-york-gold/10 px-4 py-3 text-sm">
        {loadError}. Try importing again from <a href="/plan/setup" class="text-york-red underline">plan setup</a>.
      </div>
    )
  }

  {
    plan && plan.parse_warnings.length > 0 && (
      <div class="mb-6 rounded-xl border border-york-gold/40 bg-york-gold/10 px-4 py-3 text-sm">
        <p class="font-medium">Parser notes</p>
        <ul class="mt-2 list-inside list-disc text-stone-600 dark:text-stone-300">
          {plan.parse_warnings.map((warning) => (
            <li>{warning}</li>
          ))}
        </ul>
      </div>
    )
  }

  {
    plan && (
      <script is:inline define:vars={{ planId: plan.id }}>
        try {
          sessionStorage.setItem("yorklanes-plan-id", planId);
          document.dispatchEvent(new Event("yorklanes:plan-id"));
        } catch (_) {}
      </script>
    )
  }

  {
    plan && (
      <div id="plan-editor" data-plan-id={plan.id}>
        <script id="plan-data" type="application/json" is:inline set:html={JSON.stringify(plan)} />

        <div class="plan-editor-toolbar">
          <p id="plan-dep-summary" class="text-york-muted" />
          <div class="text-right">
            <p id="plan-selected-course" class="font-medium text-york-black dark:text-white" />
            <p id="plan-link-legend" class="hidden mt-1 text-xs text-york-muted" />
          </div>
        </div>
        <p id="plan-editor-status" class="mb-3 text-xs text-york-muted" />

        <div class="plan-editor-canvas" id="plan-editor-canvas">
          <div class="plan-editor-stage" id="plan-editor-stage">
            <svg id="plan-deps-svg" class="plan-deps-layer" aria-hidden="true" />
            <div
              class:list={["plan-year-board", showSummerRow && "plan-year-board--with-summer"]}
              id="plan-editor-columns"
              style={`--year-count: ${Math.max(yearColumns.length, 1)}`}
            >
              {
                yearColumns.map((year, yearIndex) => {
                  const seasons = seasonSlotsForYear(year, showSummerRow);

                  return (
                    <section
                      class="plan-year-column"
                      data-checklist-year={year.checklistYear}
                      style={`--year-index: ${yearIndex}`}
                    >
                      <header class="plan-year-header">
                        <p class="plan-year-kicker">Year {year.checklistYear}</p>
                        <h2 class="plan-year-title">{academicSpan(year.academicYear)}</h2>
                      </header>

                      {
                        seasons.map(({ key, term, label }) => {
                          if (!term) {
                            return (
                              <div
                                class:list={[
                                  "plan-term-bubble plan-term-bubble--empty",
                                  `plan-term-bubble--${key}`,
                                ]}
                                data-season={key}
                              >
                                <div class="plan-term-header">
                                  <p class="plan-term-session">{label}</p>
                                  <p class="plan-term-meta">No courses scheduled</p>
                                </div>
                                <div class="plan-term-empty-body">
                                  <p>Add a {label.toLowerCase()} term to place courses here.</p>
                                </div>
                              </div>
                            );
                          }

                          const credits = termCredits(term);
                          const count = courseCount(term);

                          return (
                            <div
                              class:list={["plan-term-bubble", `plan-term-bubble--${key}`]}
                              data-term-id={term.id}
                              data-season={key}
                            >
                              <div class="plan-term-header">
                                <p class="plan-term-session">{label}</p>
                                <h3 class="plan-term-title">{term.label}</h3>
                              </div>

                              <ul class="plan-course-list" data-term-id={term.id} data-drop-zone>
                                {
                                  term.courses.length > 0 ? (
                                    term.courses.map((course: PlanCourse) => {
                                      const isStub = course.entry_kind === "stub";
                                      const displayLabel = isStub
                                        ? (course.section_label ?? course.title ?? course.course_code)
                                        : course.course_code;
                                      return (
                                        <li
                                          class:list={["plan-course-card", { "plan-course-card--stub": isStub }]}
                                          data-course-id={course.id}
                                          data-course-code={course.course_code}
                                          data-entry-kind={course.entry_kind ?? "course"}
                                        >
                                          {
                                            !isStub && (
                                              <label class="plan-course-complete-wrap" title="Mark as completed">
                                                <input
                                                  type="checkbox"
                                                  class="plan-course-complete"
                                                  checked={course.completed ?? false}
                                                  aria-label={`Mark ${course.course_code} as completed`}
                                                />
                                              </label>
                                            )
                                          }
                                          <span class="plan-course-warning" hidden aria-label="Unmet prerequisites">!</span>
                                          <span
                                            class="plan-course-schedule-warn"
                                            hidden
                                            aria-label="Season offering warning"
                                          >S</span>
                                          <button
                                            type="button"
                                            class="plan-course-handle"
                                            draggable="true"
                                            aria-label={`Drag ${displayLabel} to another term`}
                                          >
                                            ⋮⋮
                                          </button>
                                          <div class="plan-course-body">
                                            {
                                              isStub ? (
                                                <Fragment>
                                                  <p class="plan-course-code">{displayLabel}</p>
                                                  {
                                                    course.title && course.title !== displayLabel && (
                                                      <p class="plan-stub-options">{course.title}</p>
                                                    )
                                                  }
                                                  {
                                                    !course.title && (
                                                      <p class="text-xs text-york-muted">Pick from checklist options</p>
                                                    )
                                                  }
                                                </Fragment>
                                              ) : (
                                                <p class="plan-course-code">{course.course_code}</p>
                                              )
                                            }
                                            {
                                              course.title && !isStub && (
                                                <p class="text-xs text-york-muted">{course.title}</p>
                                              )
                                            }
                                            {
                                              course.credits != null && (
                                                <span class="plan-course-credits">{course.credits} cr</span>
                                              )
                                            }
                                          </div>
                                        </li>
                                      );
                                    })
                                  ) : (
                                    <li class="plan-course-empty">Drop courses here</li>
                                  )
                                }
                              </ul>

                              <div class="plan-term-footer">
                                <span class="plan-term-count">
                                  {count} course{count === 1 ? "" : "s"}
                                </span>
                                <span class="plan-term-credits">{credits} credits</span>
                              </div>
                            </div>
                          );
                        })
                      }
                    </section>
                  );
                })
              }
            </div>
          </div>
        </div>

        <p class="mt-4 text-xs text-york-muted">
          Click a course to show prerequisite (blue) and co-requisite (amber dashed) links · click elsewhere to hide · tick courses you have already completed · an <strong>S</strong> badge means scraped timetable history has no offerings in that Fall/Winter/Summer slot.
        </p>
      </div>
    )
  }

  {
    plan && (
      <script>
        import { initPlanEditor, readPlanFromPage } from "../../scripts/plan-editor.ts";
        const planData = readPlanFromPage();
        if (planData) {
          initPlanEditor(planData);
        }
      </script>
    )
  }
</DashboardLayout>
