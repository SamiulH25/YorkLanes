---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { fetchFaculties } from "../../lib/plans";

export const prerender = false;

const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3001";

let faculties: Awaited<ReturnType<typeof fetchFaculties>> = [];
let loadError: string | null = null;

try {
  faculties = await fetchFaculties();
} catch (error) {
  loadError = error instanceof Error ? error.message : "Could not reach API";
}
---

<DashboardLayout title="Import Checklist | YorkLanes" activeNav="plan">
  <Fragment slot="header">
    <div>
      <p class="text-xs font-medium text-york-muted">Degree plan setup</p>
      <h1 class="heading-page">Build your degree plan</h1>
      <p class="mt-0.5 text-sm text-york-muted">Download your checklist from York, upload it here, and we detect your programme automatically</p>
    </div>
  </Fragment>

  {
    loadError && (
      <div class="mb-6 rounded-xl border border-york-gold/40 bg-york-gold/10 px-4 py-3 text-sm">
        API offline ({loadError}). Faculty links below use built-in defaults. Start the API with{" "}
        <code class="font-mono text-xs">npm run dev:api</code> before parsing a file.
      </div>
    )
  }

  <form id="checklist-form" class="mx-auto max-w-2xl space-y-6" novalidate data-api-url={apiUrl}>
    <section class="surface rounded-2xl p-6" aria-labelledby="step-download-heading">
      <p class="label">Step 1</p>
      <h2 id="step-download-heading" class="mt-1 font-display text-lg font-semibold text-york-black dark:text-white">
        Download your official checklist
      </h2>
      <p class="mt-1 text-sm text-york-muted">
        Pick your faculty to get the right link, then download the PDF or DOCX for your programme.
      </p>

      <div class="mt-5">
        <label for="facultyKey" class="mb-1.5 block text-sm font-medium">Faculty (for download link)</label>
        <select
          id="facultyKey"
          name="facultyKey"
          class="w-full rounded-xl border border-york-stone/80 bg-york-cream/50 px-3 py-2.5 text-sm dark:border-white/15 dark:bg-york-navy/50"
        >
          <option value="">Select faculty...</option>
          {faculties.map((f) => (
            <option value={f.key}>{f.name}</option>
          ))}
        </select>
      </div>

      {
        faculties.map((f) => (
          <div class="faculty-panel mt-5 hidden" data-faculty-panel={f.key}>
            <div class="rounded-xl border border-york-red/20 bg-york-red/5 p-5 dark:bg-york-red/10">
              <p class="text-sm leading-relaxed text-stone-600 dark:text-stone-300">{f.instructions}</p>
              <a
                href={f.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-york mt-4 inline-flex items-center gap-2"
              >
                Open faculty checklist page
                <span aria-hidden="true">↗</span>
              </a>
              <p class="mt-3 text-xs text-york-muted">Accepted formats: {f.fileHint}</p>
            </div>
          </div>
        ))
      }

      <p class="mt-4 text-xs text-york-muted">Already have your checklist file? Skip to step 2 below.</p>
    </section>

    <section class="surface rounded-2xl p-6" aria-labelledby="step-upload-heading">
      <p class="label">Step 2</p>
      <h2 id="step-upload-heading" class="mt-1 font-display text-lg font-semibold text-york-black dark:text-white">
        Upload your checklist
      </h2>
      <p class="mt-1 text-sm text-york-muted">
        We read your programme name, start year, and courses directly from the file.
      </p>

      <label
        id="upload-dropzone"
        class="mt-5 flex min-h-[180px] cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-york-stone/70 bg-york-cream/40 px-6 py-10 text-center transition-colors hover:border-york-red/50 hover:bg-york-red/5 focus-within:outline-none focus-within:ring-2 focus-within:ring-york-red dark:border-white/20 dark:bg-york-navy/30 dark:hover:bg-york-red/10"
      >
        <input
          id="checklist"
          name="checklist"
          type="file"
          accept=".pdf,.docx,.doc,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
          class="sr-only"
        />
        <div class="pointer-events-none select-none">
          <svg class="mx-auto mb-3 h-10 w-10 text-york-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
          </svg>
          <p class="text-sm font-medium text-york-black dark:text-white">Drop your checklist here</p>
          <p class="mt-1 text-xs text-york-muted">PDF or DOCX from your faculty site</p>
          <p class="mt-3 text-xs font-medium text-york-red">or click to browse</p>
        </div>
      </label>

      <div id="file-preview" class="mt-4 hidden rounded-xl border border-york-stone/60 bg-york-cream/50 px-4 py-3 dark:border-white/15 dark:bg-york-navy/40">
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <p class="text-xs font-medium uppercase tracking-widest text-york-muted">Selected file</p>
            <p id="file-name" class="truncate text-sm font-semibold text-york-black dark:text-white"></p>
            <p id="file-size" class="text-xs text-york-muted"></p>
          </div>
          <button type="button" id="file-clear" class="shrink-0 text-sm font-medium text-york-red hover:underline">
            Remove
          </button>
        </div>
      </div>

      <button type="submit" class="btn-york mt-6 w-full" id="submit-btn">
        Parse checklist and build plan
      </button>
      <p id="form-status" class="hidden mt-3 text-sm"></p>
    </section>
  </form>

  <script>
    import { initPlanSetup } from "../../scripts/plan-setup.ts";
    initPlanSetup();
  </script>
</DashboardLayout>
