---
/** Schedule builder — Nabeela. Task guide: docs/tasks/schedule.md */
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { fetchSchedules } from "../../lib/schedules";

export const prerender = false;

let apiMessage: string | undefined;
let loadError: string | null = null;

try {
  const data = await fetchSchedules();
  apiMessage = data.message;
} catch (error) {
  loadError = error instanceof Error ? error.message : "API unavailable";
}
---

<DashboardLayout title="Schedule | YorkLanes" activeNav="schedule">
  <Fragment slot="header">
    <h1 class="heading-page">Schedule builder</h1>
  </Fragment>

  <section class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <p class="text-sm font-semibold text-york-red">Schedule Builder</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">Build your weekly timetable</h2>
      <p class="mt-2 text-slate-600 dark:text-slate-300">
        Add a manual course block with a course code, day, and time. Saved entries appear in the weekly preview for this demo.
      </p>

      {loadError && <p class="mt-4 text-sm text-york-red">API status: {loadError}</p>}
      {apiMessage && <p class="mt-4 text-sm text-green-700 dark:text-green-400">API status: {apiMessage}</p>}
    </div>

    <div class="grid gap-6 lg:grid-cols-[380px_1fr]">
      <form id="schedule-form" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Add schedule entry</h3>

        <label class="mt-4 block">
          <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Course code</span>
          <input
            id="course-code"
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white"
            placeholder="e.g. EECS 3421"
            required
          />
        </label>

        <label class="mt-4 block">
          <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Day</span>
          <select
            id="day"
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white"
          >
            <option>Monday</option>
            <option>Tuesday</option>
            <option>Wednesday</option>
            <option>Thursday</option>
            <option>Friday</option>
          </select>
        </label>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <label>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Start</span>
            <input
              id="start-time"
              type="time"
              class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white"
              required
            />
          </label>

          <label>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200">End</span>
            <input
              id="end-time"
              type="time"
              class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-900 dark:border-slate-600 dark:bg-slate-800 dark:text-white"
              required
            />
          </label>
        </div>

        <button
          type="submit"
          class="mt-5 w-full rounded-lg bg-york-red px-4 py-2 font-semibold text-white"
        >
          Save entry
        </button>
      </form>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Weekly preview</h3>
        <div id="schedule-list" class="mt-4 space-y-3">
          <p id="empty-message" class="rounded-xl border border-dashed border-slate-300 p-4 text-sm text-slate-500 dark:border-slate-600 dark:text-slate-400">
            No schedule entries yet. Add one using the form.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector<HTMLFormElement>("#schedule-form");
    const list = document.querySelector<HTMLDivElement>("#schedule-list");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();

      const courseInput = document.querySelector<HTMLInputElement>("#course-code");
      const daySelect = document.querySelector<HTMLSelectElement>("#day");
      const startInput = document.querySelector<HTMLInputElement>("#start-time");
      const endInput = document.querySelector<HTMLInputElement>("#end-time");

      const course = courseInput?.value.trim();
      const day = daySelect?.value;
      const start = startInput?.value;
      const end = endInput?.value;

      if (!course || !day || !start || !end || !list) return;

      document.querySelector("#empty-message")?.remove();

      const card = document.createElement("div");
      card.className = "rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-800";
      card.innerHTML = `
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="font-semibold text-slate-900 dark:text-white">${course}</p>
            <p class="text-sm text-slate-600 dark:text-slate-300">${day} • ${start} - ${end}</p>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 dark:bg-slate-900 dark:text-slate-200">
            Manual
          </span>
        </div>
      `;

      list.appendChild(card);
      form.reset();
    });
  </script>
</DashboardLayout>