{
  "name": "yorklanes",
  "version": "0.1.0",
  "private": true,
  "description": "YorkPath student dashboard (York University course planning)",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build -w apps/web && npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:push": "supabase db push",
    "supabase:diff": "supabase db diff -f",
    "supabase:studio": "supabase studio",
    "scraper:test": "cd services/scraper && python test_scraper.py",
    "scraper:fixture": "cd services/scraper && python scrape_courses.py fixture",
    "scraper:yoki": "cd services/scraper && python scrape_courses.py yoki --subject eecs --out output/eecs.json"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "supabase": "^2.107.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
